---
import { navItems, primaryNavItems } from '../data/nav';

const pathname = Astro.url.pathname;
// Highlight covers the whole section (/blog/* lights up the blog tab)…
const isActive = (href: string) =>
  pathname === href || (href !== '/' && pathname.startsWith(href + '/'));
// …but aria-current="page" is reserved for the exact page (ARIA semantics).
const isCurrentPage = (href: string) => pathname === href || pathname === href + '/';
---

<header class="sticky top-0 z-40 border-b bg-background/90 backdrop-blur supports-[backdrop-filter]:bg-background/75">
  <div class="site-shell flex min-h-[3rem] items-center justify-between gap-4 py-2 text-[0.7rem] uppercase tracking-[0.16em] text-muted-foreground">
    <div class="flex min-w-0 items-center gap-3">
      <a href="/" class="flex items-center gap-2 whitespace-nowrap text-foreground">
        <span class="status-dot"></span>
        <span>adrian.os</span>
      </a>
      <span class="hidden sm:inline">nyc / public runtime</span>
    </div>

    <nav class="hidden items-center gap-5 sm:flex" aria-label="Primary">
      {primaryNavItems.map((item) => (
        <a
          href={item.href}
          aria-current={isCurrentPage(item.href) ? 'page' : undefined}
          class:list={[
            'border-b pb-0.5 transition-colors',
            isActive(item.href)
              ? 'border-[hsl(var(--accent)/0.6)] text-[hsl(var(--accent))]'
              : 'border-transparent hover:text-foreground',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <button
        id="theme-toggle"
        class="inline-flex h-8 w-8 items-center justify-center rounded-sm border border-border text-muted-foreground hover:text-foreground"
        aria-label="Toggle dark mode"
      >
        <svg id="sun-icon" class="hidden h-[16px] w-[16px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="5" stroke-width="1.5"></circle>
          <path stroke-linecap="round" stroke-width="1.5" d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>
        </svg>
        <svg id="moon-icon" class="h-[16px] w-[16px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
        </svg>
      </button>

      <button
        id="menu-toggle"
        class="inline-flex h-8 w-8 items-center justify-center rounded-sm border border-border text-foreground sm:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="menu-open-icon" class="h-[16px] w-[16px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg id="menu-close-icon" class="hidden h-[16px] w-[16px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="site-shell hidden border-t border-border py-3 sm:hidden" aria-label="Mobile">
    <div class="grid gap-3 text-[0.72rem] uppercase tracking-[0.16em]">
      {navItems.map((item) => (
        <a
          href={item.href}
          aria-current={isCurrentPage(item.href) ? 'page' : undefined}
          class:list={[
            'py-1',
            isActive(item.href) ? 'text-[hsl(var(--accent))]' : 'text-muted-foreground',
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');

  function setMenuOpen(open: boolean) {
    menuToggle?.setAttribute('aria-expanded', String(open));
    mobileNav?.classList.toggle('hidden', !open);
    openIcon?.classList.toggle('hidden', open);
    closeIcon?.classList.toggle('hidden', !open);
  }

  menuToggle?.addEventListener('click', () => {
    setMenuOpen(menuToggle.getAttribute('aria-expanded') !== 'true');
  });

  // Escape closes the menu and hands focus back to the toggle.
  document.addEventListener('keydown', (e) => {
    if (e.defaultPrevented) return; // let overlays that claimed Escape keep it
    if (e.key === 'Escape' && menuToggle?.getAttribute('aria-expanded') === 'true') {
      setMenuOpen(false);
      menuToggle.focus();
    }
  });

  // Tapping outside the header closes the open menu.
  const header = menuToggle?.closest('header');
  document.addEventListener('click', (e) => {
    if (
      menuToggle?.getAttribute('aria-expanded') === 'true' &&
      e.target instanceof Node &&
      !header?.contains(e.target)
    ) {
      setMenuOpen(false);
    }
  });

  const themeToggle = document.getElementById('theme-toggle');
  const sunIcon = document.getElementById('sun-icon');
  const moonIcon = document.getElementById('moon-icon');

  function updateIcons() {
    const isDark = document.documentElement.classList.contains('dark');
    sunIcon?.classList.toggle('hidden', !isDark);
    moonIcon?.classList.toggle('hidden', isDark);
  }

  updateIcons();

  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.contains('dark');
    document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'light' : 'dark');
    updateIcons();
  });
</script>
