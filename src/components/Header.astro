---
import { navItems } from '../data/nav';
const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname === href || pathname.startsWith(href + '/');
const isCurrentPage = (href: string) => pathname === href || pathname === href + '/';
---

<header class="sticky top-0 z-40 border-b border-[var(--line)] bg-[color:rgb(247_243_234_/_0.86)] backdrop-blur supports-[backdrop-filter]:bg-[color:rgb(247_243_234_/_0.74)]">
  <div class="mx-auto flex max-w-[52rem] items-center justify-between gap-6 px-6 py-3 font-sans text-sm">
    <a href="/" class="font-medium lowercase tracking-tight text-[var(--ink)] no-underline hover:text-[var(--accent-ink)]">adrian lumley</a>
    <nav class="flex flex-wrap items-center justify-end gap-x-5 gap-y-2" aria-label="primary">
      {navItems.map((item) => (
        <a
          href={item.href}
          aria-current={isCurrentPage(item.href) ? 'page' : undefined}
          class:list={[
            'no-underline text-sm lowercase text-[var(--ink-soft)] hover:text-[var(--ink)]',
            isActive(item.href) ? 'border-b border-[var(--accent)] text-[var(--ink)]' : '',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
