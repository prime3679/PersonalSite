---
import { navItems } from '../data/nav';
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname;
const normalizePath = (path: string) => path.endsWith('/') && path !== '/' ? path.slice(0, -1) : path;
const currentPath = normalizePath(pathname);

const isActive = (href: string) => {
  const normalizedHref = normalizePath(href);
  return currentPath === normalizedHref || (normalizedHref !== '/' && currentPath.startsWith(normalizedHref + '/'));
};

const isCurrentPage = (href: string) => currentPath === normalizePath(href);
---

<header class="site-header" data-site-header>
  <div class="site-header__bar" data-header-bar>
    <a href="/" class="site-header__wordmark site-header__logo">adrian lumley</a>

    <div class="site-header__actions">
      <nav class="site-header__desktop-nav" data-header-desktop-nav aria-label="Primary">
        {navItems.map((item) => (
          <a
            href={item.href}
            aria-current={isCurrentPage(item.href) ? 'page' : undefined}
            class:list={['site-header__nav-link', isActive(item.href) && 'is-active']}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="site-header__theme-toggle" aria-label="Theme">
        <ThemeToggle />
      </div>

      <button
        id="menu-toggle"
        class="site-header__menu-toggle"
        data-header-menu-toggle
        type="button"
        aria-label="Open site menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </button>
    </div>
  </div>

  <nav
    id="mobile-nav"
    class="site-header__mobile-panel"
    data-header-mobile-panel
    aria-label="Mobile"
    aria-hidden="true"
  >
    {navItems.map((item) => (
      <a
        href={item.href}
        aria-current={isCurrentPage(item.href) ? 'page' : undefined}
        class:list={['site-header__mobile-link', isActive(item.href) && 'is-active']}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const header = document.querySelector('[data-site-header]');
  const menuToggle = document.querySelector('[data-header-menu-toggle]');
  const mobilePanel = document.querySelector('[data-header-mobile-panel]');
  const mobileLinks = mobilePanel?.querySelectorAll('a') ?? [];

  function setMenuOpen(open: boolean) {
    menuToggle?.setAttribute('aria-expanded', String(open));
    menuToggle?.setAttribute('aria-label', open ? 'Close site menu' : 'Open site menu');
    mobilePanel?.setAttribute('aria-hidden', String(!open));
    header?.classList.toggle('is-menu-open', open);
  }

  menuToggle?.addEventListener('click', () => {
    setMenuOpen(menuToggle.getAttribute('aria-expanded') !== 'true');
  });

  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => setMenuOpen(false));
  });

  document.addEventListener('keydown', (event) => {
    if (event.defaultPrevented) return;
    if (event.key === 'Escape' && menuToggle?.getAttribute('aria-expanded') === 'true') {
      setMenuOpen(false);
      if (menuToggle instanceof HTMLElement) menuToggle.focus();
    }
  });

  document.addEventListener('click', (event) => {
    if (
      menuToggle?.getAttribute('aria-expanded') === 'true' &&
      event.target instanceof Node &&
      !header?.contains(event.target)
    ) {
      setMenuOpen(false);
    }
  });
</script>

<style>
  .site-header {
    position: relative;
    z-index: 40;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
    color: var(--ink);
  }

  .site-header__logo {
    display: inline-flex;
    min-width: 0;
    min-height: 45px;
    align-items: center;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .site-header__mobile-link {
    display: flex;
    min-height: 45px;
    align-items: center;
    padding: .3125rem 0;
  }

  .site-header__bar {
    box-sizing: border-box;
    width: 100%;
    max-width: 52rem;
    min-height: 4.25rem;
    margin: 0 auto;
    padding: 16px clamp(var(--s5), 5vw, var(--s7));
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .site-header__wordmark {
    position: relative;
    flex: 0 0 auto;
    color: var(--ink);
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.015em;
    text-decoration: none;
    white-space: nowrap;
    transition: font-weight 220ms var(--ease);
  }

  /* a small accent dot answers the hover, like a status light coming on.
     absolutely positioned so the wordmark never gains width or wraps. */
  .site-header__wordmark::after {
    content: '';
    position: absolute;
    right: -0.65em;
    top: 50%;
    width: 0.3em;
    height: 0.3em;
    margin-top: -0.15em;
    border-radius: 999px;
    background: var(--accent);
    opacity: 0;
    transform: scale(0.4);
    transition: opacity 200ms var(--ease), transform 200ms var(--ease);
  }

  .site-header__wordmark:hover,
  .site-header__wordmark:focus-visible {
    font-weight: 585;
  }

  .site-header__wordmark:hover::after,
  .site-header__wordmark:focus-visible::after {
    opacity: 1;
    transform: scale(1);
  }

  .site-header__desktop-nav {
    display: none;
    align-items: center;
    justify-content: flex-end;
    gap: 20px;
    min-width: 0;
    white-space: nowrap;
  }

  .site-header__actions {
    display: flex;
    min-width: 0;
    flex: 0 1 auto;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
  }

  .site-header__theme-toggle {
    display: inline-flex;
    flex: 0 0 auto;
  }

  .site-header :global(.theme-toggle) {
    min-height: 40px;
    border-radius: 999px;
    padding: 0 .7rem;
    background: color-mix(in srgb, var(--paper-raised) 68%, transparent);
    font-size: .64rem;
    white-space: nowrap;
  }

  .site-header__nav-link,
  .site-header__mobile-link {
    color: var(--ink-soft);
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 450;
    letter-spacing: 0.03em;
    text-transform: lowercase;
    text-decoration: none;
    text-underline-offset: 5px;
    transition: color 160ms ease, text-decoration-color 160ms ease, opacity 180ms ease, transform 180ms ease;
  }

  .site-header__nav-link:hover,
  .site-header__mobile-link:hover {
    color: var(--ink);
  }

  /* desktop nav underline draws in from the left on hover */
  .site-header__nav-link {
    position: relative;
  }

  .site-header__nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -4px;
    height: 1.5px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 200ms var(--ease);
  }

  .site-header__nav-link:hover::after {
    transform: scaleX(1);
  }

  .site-header__nav-link.is-active::after {
    display: none;
  }

  .site-header__nav-link.is-active {
    color: var(--ink);
    text-decoration-line: underline;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 1.5px;
  }

  .site-header__menu-toggle {
    width: 45px;
    height: 45px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--ink);
    display: inline-flex;
    flex: 0 0 auto;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
  }

  .site-header__menu-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    border-radius: 999px;
    background: currentColor;
    transform-origin: center;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .site-header.is-menu-open .site-header__menu-toggle span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }

  .site-header.is-menu-open .site-header__menu-toggle span:nth-child(2) {
    opacity: 0;
  }

  .site-header.is-menu-open .site-header__menu-toggle span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  .site-header__mobile-panel {
    box-sizing: border-box;
    width: 100%;
    max-width: 52rem;
    max-height: 0;
    margin: 0 auto;
    padding: 0 clamp(var(--s5), 5vw, var(--s7));
    opacity: 0;
    overflow: hidden;
    pointer-events: none;
    visibility: hidden;
    transform: translateY(-4px);
    transition: max-height 180ms ease, opacity 180ms ease, transform 180ms ease, padding-bottom 180ms ease, visibility 0ms linear 180ms;
  }

  .site-header.is-menu-open .site-header__mobile-panel {
    max-height: 320px;
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
    transform: translateY(0);
    padding-bottom: 14px;
    transition-delay: 0ms;
  }

  .site-header__mobile-panel > a {
    min-height: 45px;
    display: flex;
    align-items: center;
    border-top: 1px solid var(--line);
  }

  .site-header__mobile-link.is-active {
    color: var(--accent-ink);
  }

  .site-header__wordmark:focus-visible,
  .site-header__nav-link:focus-visible,
  .site-header__mobile-link:focus-visible,
  .site-header__menu-toggle:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: 4px;
  }

  @media (min-width: 720px) {
    .site-header__bar {
      padding-top: 17px;
      padding-bottom: 17px;
    }

    .site-header__desktop-nav {
      display: flex;
    }

    .site-header__actions {
      gap: 14px;
    }

    .site-header__menu-toggle,
    .site-header__mobile-panel {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header *,
    .site-header *::before,
    .site-header *::after {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
    }
  }
</style>
