---
import { navItems } from '../data/nav';

const pathname = Astro.url.pathname;
const normalizePath = (path: string) => path.endsWith('/') && path !== '/' ? path.slice(0, -1) : path;
const currentPath = normalizePath(pathname);

const isActive = (href: string) => {
  const normalizedHref = normalizePath(href);
  return currentPath === normalizedHref || (normalizedHref !== '/' && currentPath.startsWith(normalizedHref + '/'));
};

const isCurrentPage = (href: string) => currentPath === normalizePath(href);
---

<header class="site-header" data-site-header>
  <div class="site-header__bar" data-header-bar>
    <a href="/" class="site-header__wordmark">adrian lumley</a>

    <nav class="site-header__desktop-nav" data-header-desktop-nav aria-label="Primary">
      {navItems.map((item) => (
        <a
          href={item.href}
          aria-current={isCurrentPage(item.href) ? 'page' : undefined}
          class:list={['site-header__nav-link', isActive(item.href) && 'is-active']}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <button
      id="menu-toggle"
      class="site-header__menu-toggle"
      data-header-menu-toggle
      type="button"
      aria-label="Open site menu"
      aria-expanded="false"
      aria-controls="site-mobile-nav"
    >
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
  </div>

  <nav
    id="site-mobile-nav"
    class="site-header__mobile-panel"
    data-header-mobile-panel
    aria-label="Mobile"
    aria-hidden="true"
  >
    {navItems.map((item) => (
      <a
        href={item.href}
        aria-current={isCurrentPage(item.href) ? 'page' : undefined}
        class:list={['site-header__mobile-link', isActive(item.href) && 'is-active']}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const header = document.querySelector('[data-site-header]');
  const menuToggle = document.querySelector('[data-header-menu-toggle]');
  const mobilePanel = document.querySelector('[data-header-mobile-panel]');
  const mobileLinks = mobilePanel?.querySelectorAll('a') ?? [];

  function setMenuOpen(open: boolean) {
    menuToggle?.setAttribute('aria-expanded', String(open));
    menuToggle?.setAttribute('aria-label', open ? 'Close site menu' : 'Open site menu');
    mobilePanel?.setAttribute('aria-hidden', String(!open));
    header?.classList.toggle('is-menu-open', open);
  }

  menuToggle?.addEventListener('click', () => {
    setMenuOpen(menuToggle.getAttribute('aria-expanded') !== 'true');
  });

  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => setMenuOpen(false));
  });

  document.addEventListener('keydown', (event) => {
    if (event.defaultPrevented) return;
    if (event.key === 'Escape' && menuToggle?.getAttribute('aria-expanded') === 'true') {
      setMenuOpen(false);
      if (menuToggle instanceof HTMLElement) menuToggle.focus();
    }
  });

  document.addEventListener('click', (event) => {
    if (
      menuToggle?.getAttribute('aria-expanded') === 'true' &&
      event.target instanceof Node &&
      !header?.contains(event.target)
    ) {
      setMenuOpen(false);
    }
  });
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;450;500&family=Newsreader:opsz,wght@6..72,500&display=swap');

  .site-header {
    --paper: #f7f2ea;
    --ink: #201915;
    --ink-soft: #6d625a;
    --line: rgba(32, 25, 21, 0.16);
    --accent: #b6694f;
    --accent-ink: #8f442f;

    position: relative;
    z-index: 40;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
    color: var(--ink);
  }

  .site-header__bar {
    box-sizing: border-box;
    width: 100%;
    max-width: 72rem;
    min-height: 4.25rem;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .site-header__wordmark {
    flex: 0 0 auto;
    color: var(--ink);
    font-family: 'Newsreader', Georgia, 'Times New Roman', serif;
    font-size: 1.2rem;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.015em;
    text-decoration: none;
    white-space: nowrap;
  }

  .site-header__desktop-nav {
    display: none;
    align-items: center;
    justify-content: flex-end;
    gap: 20px;
    min-width: 0;
    white-space: nowrap;
  }

  .site-header__nav-link,
  .site-header__mobile-link {
    color: var(--ink-soft);
    font-family: 'Geist Mono', 'JetBrains Mono', 'SF Mono', Monaco, Consolas, monospace;
    font-size: 13px;
    font-weight: 450;
    letter-spacing: 0.03em;
    text-transform: lowercase;
    text-decoration: none;
    text-underline-offset: 5px;
    transition: color 160ms ease, text-decoration-color 160ms ease, opacity 180ms ease, transform 180ms ease;
  }

  .site-header__nav-link:hover,
  .site-header__mobile-link:hover {
    color: var(--ink);
  }

  .site-header__nav-link.is-active {
    color: var(--ink);
    text-decoration-line: underline;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 1.5px;
  }

  .site-header__menu-toggle {
    width: 44px;
    height: 44px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--ink);
    display: inline-flex;
    flex: 0 0 auto;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
  }

  .site-header__menu-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    border-radius: 999px;
    background: currentColor;
    transform-origin: center;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .site-header.is-menu-open .site-header__menu-toggle span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }

  .site-header.is-menu-open .site-header__menu-toggle span:nth-child(2) {
    opacity: 0;
  }

  .site-header.is-menu-open .site-header__menu-toggle span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  .site-header__mobile-panel {
    box-sizing: border-box;
    width: 100%;
    max-width: 72rem;
    max-height: 0;
    margin: 0 auto;
    padding: 0 24px;
    opacity: 0;
    overflow: hidden;
    pointer-events: none;
    visibility: hidden;
    transform: translateY(-4px);
    transition: max-height 180ms ease, opacity 180ms ease, transform 180ms ease, padding-bottom 180ms ease, visibility 0ms linear 180ms;
  }

  .site-header.is-menu-open .site-header__mobile-panel {
    max-height: 320px;
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
    transform: translateY(0);
    padding-bottom: 14px;
    transition-delay: 0ms;
  }

  .site-header__mobile-panel > a {
    min-height: 44px;
    display: flex;
    align-items: center;
    border-top: 1px solid var(--line);
  }

  .site-header__mobile-link.is-active {
    color: var(--accent-ink);
  }

  .site-header__wordmark:focus-visible,
  .site-header__nav-link:focus-visible,
  .site-header__mobile-link:focus-visible,
  .site-header__menu-toggle:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: 4px;
  }

  @media (min-width: 720px) {
    .site-header__bar {
      padding: 17px 28px;
    }

    .site-header__desktop-nav {
      display: flex;
    }

    .site-header__menu-toggle,
    .site-header__mobile-panel {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .site-header__bar {
      padding-left: 18px;
      padding-right: 18px;
    }

    .site-header__mobile-panel {
      padding-left: 18px;
      padding-right: 18px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header *,
    .site-header *::before,
    .site-header *::after {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
    }
  }
</style>
