---
import { daysRunning } from '../data/rogue';
import { tracePoints, toSvgPath, traceSeed } from '../lib/trace';

// strip-chart recorder: one quiet line. the static svg is the no-js and
// reduced-motion state; the canvas redraws the same seeded line slowly
// when motion is allowed. rust only appears on a fresh live status.
const WIDTH = 600;
const HEIGHT = 64;
const SAMPLES = 180;

const now = new Date();
const seed = traceSeed(daysRunning(now), now);
const path = toSvgPath(tracePoints(seed, WIDTH, HEIGHT, SAMPLES));
---

<div class="signal-trace" data-signal-trace data-seed={seed} aria-hidden="true">
  <svg
    class="signal-trace__svg"
    viewBox={`0 0 ${WIDTH} ${HEIGHT}`}
    preserveAspectRatio="none"
    fill="none"
  >
    <path d={path} stroke="var(--panel-soft)" stroke-width="1.5" vector-effect="non-scaling-stroke"></path>
  </svg>
  <canvas class="signal-trace__canvas" width={WIDTH} height={HEIGHT}></canvas>
</div>

<script>
  import { tracePoints } from '../lib/trace';

  const host = document.querySelector<HTMLElement>('[data-signal-trace]');

  if (host && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const canvas = host.querySelector<HTMLCanvasElement>('.signal-trace__canvas');
    const svg = host.querySelector<SVGElement>('.signal-trace__svg');
    const ctx = canvas?.getContext('2d');

    if (canvas && svg && ctx) {
      const seed = Number(host.dataset.seed) || 1;
      const DURATION_MS = 25000;

      let color = getComputedStyle(host).getPropertyValue('--trace-quiet').trim() || '#9c9384';
      let amplitude = 1;
      let points = tracePoints(seed, canvas.width, canvas.height, 180, amplitude);
      let start: number | null = null;
      let progress = 0;
      let visible = false;
      let raf = 0;

      const draw = () => {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.strokeStyle = color;
        ctx.lineWidth = 1.5;
        ctx.beginPath();
        const count = Math.max(2, Math.floor(points.length * progress));
        ctx.moveTo(points[0][0], points[0][1]);
        for (let i = 1; i < count; i++) ctx.lineTo(points[i][0], points[i][1]);
        ctx.stroke();
      };

      const tick = (ts: number) => {
        if (start === null) start = ts;
        progress = Math.min(1, (ts - start) / DURATION_MS);
        draw();
        if (progress < 1 && visible && !document.hidden) {
          raf = requestAnimationFrame(tick);
        } else if (progress >= 1) {
          host.removeAttribute('data-animating');
        }
      };

      const run = () => {
        if (progress >= 1 || !visible || document.hidden) return;
        host.setAttribute('data-animating', '');
        svg.style.display = 'none';
        // resume from elapsed progress rather than restarting
        start = null;
        const consumed = progress * DURATION_MS;
        raf = requestAnimationFrame((ts) => {
          start = ts - consumed;
          tick(ts);
        });
      };

      const halt = () => {
        cancelAnimationFrame(raf);
        host.removeAttribute('data-animating');
      };

      const observer = new IntersectionObserver((entries) => {
        visible = entries.some((e) => e.isIntersecting);
        if (visible) run();
        else halt();
      });
      observer.observe(host);

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) halt();
        else run();
      });

      document.addEventListener('rogue:status', (event) => {
        const detail = (event as CustomEvent).detail;
        if (detail?.status === 'live') {
          color = getComputedStyle(host).getPropertyValue('--trace-live').trim() || '#c9663f';
          const loops = typeof detail.loops_today === 'number' ? detail.loops_today : 0;
          amplitude = Math.min(1.4, Math.max(0.6, 0.8 + loops / 50));
          points = tracePoints(seed, canvas.width, canvas.height, 180, amplitude);
          draw();
        }
      });
    }
  }
</script>

<style>
  .signal-trace {
    --trace-quiet: var(--panel-soft);
    --trace-live: var(--accent-bright);
    position: relative;
    width: 100%;
    height: 4rem;
    margin-bottom: var(--s4);
  }
  .signal-trace__svg,
  .signal-trace__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
