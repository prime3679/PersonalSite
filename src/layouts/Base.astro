---
import '../styles/global.css';
import { siteMetadata } from '../data/siteMetadata';
import { navItems } from '../data/nav';
import Header from '../components/Header.astro';

interface ArticleData {
  headline: string;
  description: string;
  datePublished: string;
  url: string;
}

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  article?: ArticleData;
  mainClass?: string;
  extraMainClass?: string;
}

const {
  title = siteMetadata.title,
  description = siteMetadata.description,
  ogImage: ogImageOverride = '/og/home.png',
  article,
  mainClass = 'site-main',
  extraMainClass,
} = Astro.props;
const fullTitle = title === siteMetadata.title ? title : `${title} · ${siteMetadata.title}`;
const ogImageUrl = new URL(ogImageOverride, Astro.site).href;

const structuredData: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${siteMetadata.url}/#person`,
      name: siteMetadata.author,
      url: siteMetadata.url,
      jobTitle: siteMetadata.jobTitle,
      worksFor: { '@type': 'Organization', name: siteMetadata.worksFor.name },
      sameAs: siteMetadata.social,
      description: 'director of product at salesforce. previously siriusxm, disney+, and ea. based in nyc.',
      knowsAbout: ['product management', 'artificial intelligence', 'enterprise software', 'emerging technology'],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteMetadata.url}/#website`,
      url: siteMetadata.url,
      name: siteMetadata.title,
      publisher: { '@id': `${siteMetadata.url}/#person` },
    },
    ...(article ? [{
      '@type': 'Article',
      headline: article.headline,
      datePublished: article.datePublished,
      description: article.description,
      author: { '@id': `${siteMetadata.url}/#person` },
      publisher: { '@id': `${siteMetadata.url}/#person` },
      url: article.url,
    }] : []),
  ],
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://cloud.umami.is; connect-src 'self' https://cloud.umami.is; style-src 'self' 'unsafe-inline'; form-action 'self' https://formspree.io; object-src 'none'; base-uri 'self'; upgrade-insecure-requests;">
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:image" content={ogImageUrl} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  <link rel="canonical" href={Astro.url.href} />
  <link rel="alternate" type="application/rss+xml" title={`${siteMetadata.title} · writing`} href="/rss.xml" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#f7f3ea" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="author" content={siteMetadata.author} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="aa267d21-11bc-40c3-a359-974f47e24791"></script>
</head>
<body>
  <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:left-3 focus:top-3 focus:z-50 focus:bg-[var(--paper-raised)] focus:px-4 focus:py-2 focus:font-sans focus:text-sm">skip to content</a>
  <Header />
  <main id="main" tabindex="-1" class:list={[mainClass, extraMainClass, 'focus:outline-none']}>
    <slot />
  </main>
  <footer class="border-t border-[var(--line)] py-8">
    <div class="mx-auto flex max-w-[52rem] flex-col items-start justify-between gap-4 px-6 font-sans text-xs text-[var(--ink-soft)] sm:flex-row sm:items-center">
      <span>adrian lumley · nyc</span>
      <nav class="flex flex-wrap gap-x-5 gap-y-2" aria-label="footer">
        {navItems.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
        <a href="/rss.xml">rss</a>
      </nav>
    </div>
  </footer>
</body>
</html>
