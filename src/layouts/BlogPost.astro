---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, date } = Astro.props;
---

<Base title={title} description={description}>
  <Header />
  <main class="mx-auto max-w-2xl px-6 py-12 font-mono">

    <!-- Header -->
    <section class="mb-10 fade-in">
      <a href="/blog" class="text-xs text-muted-foreground uppercase tracking-wider hover:text-foreground transition-colors">← blog</a>
      <h1 class="text-2xl font-normal mt-4 mb-3 leading-relaxed">{title}</h1>
      <time class="text-xs text-muted-foreground uppercase tracking-wider">
        {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </section>

    <!-- Content -->
    <article class="fade-in prose max-w-none">
      <slot />
    </article>

    <!-- Footer -->
    <footer class="mt-16 pt-8 border-t border-foreground/10 fade-in flex justify-between items-center">
      <a href="/blog" class="text-xs text-muted-foreground uppercase tracking-wider hover:text-foreground transition-colors">← all posts</a>
      <a href="/lab" class="text-xs text-muted-foreground uppercase tracking-wider hover:text-foreground transition-colors">see what i'm building →</a>
    </footer>

  </main>
</Base>
