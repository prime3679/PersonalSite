---
import Base from '../layouts/Base.astro';
---

<Base title="404" description="page not found.">
  <header class="page-header reveal">
    <p class="eyebrow">error 404</p>
    <h1 class="page-title">lost the signal</h1>
    <p class="page-standfirst">this page doesn't exist. moved, renamed, or never built. no hard feelings.</p>
  </header>

  <p class="plain-links reveal">
    <a class="touch-link" href="/">back home</a><span aria-hidden="true">·</span>
    <a class="touch-link" href="/lab">the lab</a><span aria-hidden="true">·</span>
    <a class="touch-link" href="/writing">writing</a>
  </p>
</Base>
