---
import Base from '../layouts/Base.astro';
---

<Base title="404" description="Page not found.">

  <section class="mb-16 fade-in">
    <p class="text-xs text-muted-foreground uppercase tracking-wider mb-6">error 404</p>
    <h1 class="text-2xl font-normal mb-6 leading-relaxed">lost the signal</h1>
    <p class="text-base leading-relaxed mb-4 text-foreground/80">
      this page doesn't exist — moved, renamed, or never built. no hard feelings.
    </p>
    <div class="space-y-2 mt-8 text-base">
      <p>— <a href="/" class="underline hover:no-underline">back home</a></p>
      <p>— <a href="/lab" class="underline hover:no-underline">the lab</a></p>
      <p>— <a href="/blog" class="underline hover:no-underline">the blog</a></p>
    </div>
  </section>

</Base>
