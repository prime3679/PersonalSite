---
import Base from '../layouts/Base.astro';
import PageIntro from '../components/PageIntro.astro';
import Eyebrow from '../components/Eyebrow.astro';
---

<Base title="404" description="page not found.">
  <PageIntro title="lost the signal" standfirst="this page doesn't exist. moved, renamed, or never built. no hard feelings.">
    <Eyebrow slot="pretitle"><span class="signal-flicker">error 404</span></Eyebrow>
  </PageIntro>

  <p class="plain-links reveal">
    <a class="touch-link" href="/">back home</a><span aria-hidden="true">·</span>
    <a class="touch-link" href="/lab">the lab</a><span aria-hidden="true">·</span>
    <a class="touch-link" href="/writing">writing</a>
  </p>
</Base>

<style>
  /* the error label flickers now and then, like a loose sign. */
  @media (prefers-reduced-motion: no-preference) {
    .signal-flicker {
      animation: flicker 7s steps(1, end) infinite;
    }
  }

  @keyframes flicker {
    0%, 90.9%, 95%, 100% { opacity: 1; }
    91% { opacity: .25; }
    92% { opacity: .8; }
    93% { opacity: .35; }
    94% { opacity: .9; }
  }
</style>
