---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
---

<Base title="About" description="Adrian Lumley — Director of Product Management at Salesforce. 14 years in tech across SiriusXM, Disney+, and EA. Builder, fighter, father. Based in NYC.">
  <Header />
  <main class="mx-auto max-w-2xl px-6 py-12 font-mono">

    <section class="mb-16 fade-in">
      <h1 class="text-2xl font-normal mb-6 leading-relaxed">about me.</h1>
      <p class="text-base leading-relaxed mb-4">
        i'm adrian lumley. director of product management at <a href="https://www.salesforce.com" class="underline hover:no-underline" target="_blank" rel="noopener noreferrer">salesforce</a>, where i work on emerging technology and ai adoption in the enterprise — figuring out how to take zero-to-one products from idea to shipped.
      </p>
      <p class="text-base leading-relaxed mb-4">
        14 years in tech. i've built products at <a href="/work" class="underline hover:no-underline">siriusxm, disney+, and ea</a> — streaming, global launches, companion apps, live experiences. the thread through all of it: making complex systems feel simple for the people using them.
      </p>
      <p class="text-base leading-relaxed">
        based in long island city, queens. new york is home.
      </p>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">what i build:</h2>
      <div class="space-y-3 text-base leading-relaxed">
        <p>outside of work, i build things that solve problems i actually have.</p>
        <div class="space-y-2 mt-4">
          <p class="pl-4 border-l-2 border-foreground/10"><span class="font-semibold text-foreground/80">bishop</span> — ai chief of staff. runs on openclaw. handles calendar, research, comms, and coordinates coding agents so i can focus on the work that matters.</p>
          <p class="pl-4 border-l-2 border-foreground/10"><span class="font-semibold text-foreground/80">familyos</span> — multi-agent system for family logistics. meal planning, groceries, scheduling — the invisible load, automated.</p>
          <p class="pl-4 border-l-2 border-foreground/10"><span class="font-semibold text-foreground/80">joytap</span> — ios app for sensory play. built for my daughter, useful for any toddler.</p>
          <p class="pl-4 border-l-2 border-foreground/10"><span class="font-semibold text-foreground/80">la carte</span> — restaurant discovery, done differently.</p>
          <p class="pl-4 border-l-2 border-foreground/10"><span class="font-semibold text-foreground/80">meeting price tag</span> — shows what meetings actually cost. a gentle nudge toward fewer, better meetings.</p>
        </div>
      </div>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">outside work:</h2>
      <div class="space-y-3 text-base leading-relaxed">
        <p>i train muay thai and jiu jitsu. still getting hit. still showing up.</p>
        <p>father to evelyn. partner to my person. the rest is context.</p>
      </div>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">find me:</h2>
      <div class="space-y-2 text-base leading-relaxed">
        <p>— <a href="https://www.linkedin.com/in/adrianlumley/" class="underline hover:no-underline" target="_blank" rel="noopener noreferrer">linkedin</a></p>
        <p>— <a href="https://github.com/prime3679" class="underline hover:no-underline" target="_blank" rel="noopener noreferrer">github</a></p>
        <p>— <a href="/contact" class="underline hover:no-underline">email me</a></p>
      </div>
    </section>

  </main>
</Base>
