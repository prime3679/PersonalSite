---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
---

<Base title="About" description="Adrian Lumley — Director of Product Management at Salesforce. 14 years building products at the intersection of technology and human behavior.">
  <Header />
  <main class="mx-auto max-w-2xl px-6 py-12 font-mono">

    <section class="mb-16 fade-in">
      <h1 class="text-2xl font-normal mb-6 leading-relaxed">about.</h1>
      <p class="text-base leading-relaxed mb-4">
        i'm a product leader with 14 years building technology products at scale. currently director of product management at <a href="https://www.salesforce.com" class="underline hover:no-underline" target="_blank" rel="noopener noreferrer">salesforce</a>, focused on emerging technology and ai adoption at enterprise scale.
      </p>
      <p class="text-base leading-relaxed mb-4">
        my work sits at the intersection of what's technically possible and what organizations are actually ready to absorb. that gap — between capability and adoption — is where the hard, interesting problems live.
      </p>
      <p class="text-base leading-relaxed">
        based in new york city.
      </p>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">experience:</h2>
      <div class="space-y-6 text-base leading-relaxed">
        <div>
          <p class="font-semibold text-foreground/80">salesforce <span class="font-normal text-muted-foreground text-sm">— 2025–present</span></p>
          <p class="text-foreground/70 mt-1">director of product management, emerging technology. zero-to-one product development, ai-adjacent initiatives, cross-functional partnership work.</p>
        </div>
        <div>
          <p class="font-semibold text-foreground/80">siriusxm <span class="font-normal text-muted-foreground text-sm">— prior</span></p>
          <p class="text-foreground/70 mt-1">product leadership across digital audio, streaming platforms, and connected car experiences.</p>
        </div>
        <div>
          <p class="font-semibold text-foreground/80">disney+ <span class="font-normal text-muted-foreground text-sm">— prior</span></p>
          <p class="text-foreground/70 mt-1">global product for one of the largest streaming launches in history.</p>
        </div>
        <div>
          <p class="font-semibold text-foreground/80">ea <span class="font-normal text-muted-foreground text-sm">— prior</span></p>
          <p class="text-foreground/70 mt-1">companion apps, live services, and gaming platform products.</p>
        </div>
      </div>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">what i'm good at:</h2>
      <div class="space-y-2 text-base leading-relaxed text-foreground/80">
        <p>— taking 0→1 products through the messy middle to shipped</p>
        <p>— making technical complexity legible to executives and stakeholders</p>
        <p>— building alignment across organizations that don't naturally agree</p>
        <p>— shipping in large orgs without losing the plot</p>
      </div>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">open to:</h2>
      <div class="space-y-2 text-base leading-relaxed text-foreground/80">
        <p>— advisory roles at the right early-stage companies</p>
        <p>— conversations about ai, enterprise product, and the future of how organizations work</p>
        <p>— selective consulting on ai product strategy</p>
      </div>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">find me:</h2>
      <div class="space-y-2 text-base leading-relaxed">
        <p>— <a href="https://www.linkedin.com/in/adrianlumley/" class="underline hover:no-underline" target="_blank" rel="noopener noreferrer">linkedin</a></p>
        <p>— <a href="https://github.com/prime3679" class="underline hover:no-underline" target="_blank" rel="noopener noreferrer">github</a></p>
        <p>— <a href="/contact" class="underline hover:no-underline">email me</a></p>
      </div>
    </section>

  </main>
</Base>
