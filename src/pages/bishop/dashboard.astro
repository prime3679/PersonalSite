---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';

const title = "Bishop Dashboard";
const description = "Internal metrics dashboard for Bishop AI optimization project";
---

<Base title={title} description={description}>
  <Header />
  <main class="mx-auto max-w-2xl px-6 py-12 font-mono">
    
    <!-- Header -->
    <div class="mb-16">
      <h1 class="text-2xl font-normal mb-4 leading-relaxed">bishop dashboard.</h1>
      <p class="text-base leading-relaxed mb-4">
        real-time metrics for multi-model AI optimization. cost reduction: 57%. models: 7 active. 
        phase 2 validation in progress.
      </p>
      <p class="text-sm text-muted-foreground">
        last updated: <span id="last-updated">loading...</span> · 
        <button id="refresh-btn" class="underline hover:no-underline">refresh</button>
      </p>
    </div>

    <!-- Key Metrics -->
    <section class="mb-16">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">current metrics:</h2>
      
      <div class="space-y-6">
        <div class="flex justify-between items-baseline border-b border-border pb-2">
          <span>daily spend (target: $15-25)</span>
          <span class="font-semibold" id="current-spend">$19.50</span>
        </div>
        
        <div class="flex justify-between items-baseline border-b border-border pb-2">
          <span>cost reduction vs baseline</span>
          <span class="font-semibold text-green-600" id="cost-reduction">57%</span>
        </div>
        
        <div class="flex justify-between items-baseline border-b border-border pb-2">
          <span>benchmark evaluations run</span>
          <span class="font-semibold" id="benchmark-count">4 / 50</span>
        </div>
        
        <div class="flex justify-between items-baseline border-b border-border pb-2">
          <span>auto-escalation accuracy</span>
          <span class="font-semibold" id="escalation-accuracy">92%</span>
        </div>
      </div>
    </section>

    <!-- Recent Costs -->
    <section class="mb-16">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">cost trend (last 7 days):</h2>
      
      <div class="space-y-2 text-sm" id="cost-history">
        <div class="flex justify-between items-center">
          <span>feb 16</span>
          <span class="font-semibold text-green-600">$19.50</span>
        </div>
        <div class="flex justify-between items-center">
          <span>feb 15</span>
          <span class="font-semibold">$31.85</span>
        </div>
        <div class="flex justify-between items-center">
          <span>feb 14</span>
          <span class="font-semibold text-red-600">$73.11</span>
        </div>
        <div class="flex justify-between items-center">
          <span>feb 13</span>
          <span class="font-semibold">$42.10</span>
        </div>
      </div>
      
      <div class="mt-4 text-sm text-muted-foreground">
        7-day average: <span class="font-semibold">$41.64</span> · trending toward target range
      </div>
    </section>

    <!-- Model Performance -->
    <section class="mb-16">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">model benchmarks:</h2>
      
      <div class="space-y-4" id="model-performance">
        <div class="border border-border p-4">
          <div class="flex justify-between items-start mb-2">
            <span class="font-semibold">haiku 3.5</span>
            <span class="text-sm text-green-600">$0.0012</span>
          </div>
          <div class="text-sm text-muted-foreground">
            7.1s · 271 tokens · monitoring + simple tasks
          </div>
        </div>
        
        <div class="border border-border p-4">
          <div class="flex justify-between items-start mb-2">
            <span class="font-semibold">codex 5.2</span>
            <span class="text-sm text-blue-600">$0.0037</span>
          </div>
          <div class="text-sm text-muted-foreground">
            5.8s · 254 tokens · code analysis + dev tasks
          </div>
        </div>
        
        <div class="border border-border p-4">
          <div class="flex justify-between items-start mb-2">
            <span class="font-semibold">sonnet 4</span>
            <span class="text-sm text-orange-600">$0.0102</span>
          </div>
          <div class="text-sm text-muted-foreground">
            18.5s · 659 tokens · default for most work
          </div>
        </div>
        
        <div class="border border-border p-4">
          <div class="flex justify-between items-start mb-2">
            <span class="font-semibold">opus 4.6</span>
            <span class="text-sm text-red-600">$0.0358</span>
          </div>
          <div class="text-sm text-muted-foreground">
            15.7s · 457 tokens · strategic work only
          </div>
        </div>
      </div>
    </section>

    <!-- Phase Progress -->
    <section class="mb-16">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">development phases:</h2>
      
      <div class="space-y-4">
        <div>
          <div class="flex justify-between items-baseline mb-2">
            <span>phase 1: architecture</span>
            <span class="text-sm text-green-600">complete</span>
          </div>
          <div class="text-sm text-muted-foreground">
            7 models, 3 providers, auto-escalation deployed
          </div>
        </div>
        
        <div>
          <div class="flex justify-between items-baseline mb-2">
            <span>phase 2: validation</span>
            <span class="text-sm text-blue-600">in progress</span>
          </div>
          <div class="text-sm text-muted-foreground">
            cost targets, benchmark suite, quality gates
          </div>
        </div>
        
        <div>
          <div class="flex justify-between items-baseline mb-2">
            <span>phase 3: playbook</span>
            <span class="text-sm text-muted-foreground">planned</span>
          </div>
          <div class="text-sm text-muted-foreground">
            documentation with real performance data
          </div>
        </div>
      </div>
    </section>

    <!-- Activity Log -->
    <section class="mb-16">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">recent activity:</h2>
      
      <div class="space-y-3 text-sm" id="activity-log">
        <div>
          <div class="flex justify-between items-baseline">
            <span>competitive analysis completed</span>
            <span class="text-muted-foreground">4:46pm</span>
          </div>
          <div class="text-muted-foreground">gpt-5 sub-agent with strategic frameworks</div>
        </div>
        
        <div>
          <div class="flex justify-between items-baseline">
            <span>bishop-bench 4-model evaluation</span>
            <span class="text-muted-foreground">4:43pm</span>
          </div>
          <div class="text-muted-foreground">all models responding, cost data collected</div>
        </div>
        
        <div>
          <div class="flex justify-between items-baseline">
            <span>model routing architecture deployed</span>
            <span class="text-muted-foreground">3:30pm</span>
          </div>
          <div class="text-muted-foreground">auto-escalation logic validated</div>
        </div>
        
        <div>
          <div class="flex justify-between items-baseline">
            <span>security audit: clean</span>
            <span class="text-muted-foreground">4:48pm</span>
          </div>
          <div class="text-muted-foreground">0 critical, 1 warning, all ports secured</div>
        </div>
      </div>
    </section>

    <!-- Raw Data Access -->
    <section class="mb-16">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">data exports:</h2>
      
      <div class="space-y-2 text-sm">
        <div>
          <button class="underline hover:no-underline" onclick="exportCostData()">
            cost-tracking.json
          </button>
          <span class="text-muted-foreground ml-2">daily spend by provider</span>
        </div>
        
        <div>
          <button class="underline hover:no-underline" onclick="exportBenchmarkData()">
            benchmark-results.json  
          </button>
          <span class="text-muted-foreground ml-2">model performance data</span>
        </div>
        
        <div>
          <button class="underline hover:no-underline" onclick="exportEscalationData()">
            escalation-log.json
          </button>
          <span class="text-muted-foreground ml-2">auto-escalation accuracy</span>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <div class="text-sm text-muted-foreground border-t border-border pt-8">
      internal dashboard · direct url access only · 
      <a href="/bishop-development" class="underline hover:no-underline">development log</a>
    </div>

  </main>

  <script is:inline>
    // Update timestamp
    document.getElementById('last-updated').textContent = new Date().toLocaleTimeString();

    // Refresh functionality
    document.getElementById('refresh-btn').addEventListener('click', () => {
      document.getElementById('last-updated').textContent = new Date().toLocaleTimeString();
      // TODO: Add actual data refresh logic
    });

    // Data export functions
    function exportCostData() {
      // TODO: Fetch and download actual cost data
      console.log('Export cost data');
    }

    function exportBenchmarkData() {
      // TODO: Fetch and download benchmark results  
      console.log('Export benchmark data');
    }

    function exportEscalationData() {
      // TODO: Fetch and download escalation logs
      console.log('Export escalation data');
    }
  </script>
</Base>