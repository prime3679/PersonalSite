---
import Base from '../layouts/Base.astro';
import { readingTime } from '../lib/readingTime';
import { getPublishedPosts, postPath } from '../lib/content';
import { formatMonthYear } from '../lib/format';

const title = "Blog";
const description = "Monthly musings on product leadership, systems thinking, and building scalable platforms.";

const publishedPosts = await getPublishedPosts();

// Derive the tag list from published posts, most-used first.
const tagCounts = new Map<string, number>();
for (const post of publishedPosts) {
  for (const tag of post.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const allTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([tag]) => tag);
---

<Base title={title} description={description}>
  
  <!-- Intro -->
  <section class="mb-16 fade-in">
    <h1 class="text-2xl font-normal mb-6 leading-relaxed">monthly musings</h1>
    <p class="text-base leading-relaxed mb-4">
      deeper thoughts on product leadership, systems thinking, and building scalable platforms. 
      published monthly, when there's something worth saying.
    </p>
  </section>

  <!-- Tag filter -->
  {allTags.length > 0 && (
    <section class="mb-10 fade-in">
      <div class="flex flex-wrap gap-2" id="tag-filters" role="group" aria-label="Filter posts by tag">
        <button type="button" class="chip" data-tag="all" aria-pressed="true">all</button>
        {allTags.map((tag) => (
          <button type="button" class="chip" data-tag={tag} aria-pressed="false">{tag}</button>
        ))}
      </div>
    </section>
  )}

  <!-- Posts -->
  <section class="mb-16 fade-in">
    {publishedPosts.length > 0 ? (
      <div class="space-y-12" id="post-list">
        {publishedPosts.map((post) => (
          <article class="blog-post border-b border-border pb-8" data-tags={(post.data.tags ?? []).join(' ')}>
            <div class="mb-4">
              <h2 class="text-lg font-normal mb-2 leading-relaxed">
                <a href={postPath(post.slug)} class="underline hover:no-underline">
                  {post.data.title}
                </a>
              </h2>
              <time class="text-sm text-muted-foreground uppercase tracking-wider">
                {formatMonthYear(post.data.date)}
              </time>
              <span class="text-sm text-muted-foreground uppercase tracking-wider"> · {readingTime(post.body)} min read</span>
            </div>
            <p class="text-base leading-relaxed text-muted-foreground">
              {post.data.description}
            </p>
            {(post.data.tags ?? []).length > 0 && (
              <div class="flex flex-wrap gap-2 mt-3">
                {post.data.tags.map((tag) => (
                  <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="text-[10px] uppercase tracking-wider text-muted-foreground border border-border rounded-full px-2 py-0.5 hover:text-foreground hover:border-foreground transition-colors">{tag}</a>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-base text-muted-foreground mb-4">
          first post coming soon.
        </p>
        <p class="text-sm text-muted-foreground">
          building the content from voice musings and real insights.
          quality over frequency.
        </p>
      </div>
    )}
    <p id="no-matches" class="hidden text-sm text-muted-foreground text-center py-8">no posts with that tag yet.</p>
  </section>

  <!-- Footer -->
  <div class="text-sm text-muted-foreground border-t border-border pt-8">
    <p class="mb-2">
      thoughts developed from voice musings, real experience, and systems analysis.
    </p>
    <p>
      subscribe:
      <a href="/rss.xml" class="underline hover:no-underline">rss</a>
      ·
      <a href="/contact" class="underline hover:no-underline">email me</a>
      for updates when new posts drop.
    </p>
  </div>

</Base>

<script>
  const filterBar = document.getElementById('tag-filters');
  if (filterBar) {
    const chips = Array.from(filterBar.querySelectorAll('[data-tag]'));
    const posts = Array.from(document.querySelectorAll('.blog-post'));
    const noMatches = document.getElementById('no-matches');

    function applyFilter(tag: string) {
      let visible = 0;
      chips.forEach((c) => c.setAttribute('aria-pressed', String(c.getAttribute('data-tag') === tag)));
      posts.forEach((post) => {
        const tags = (post.getAttribute('data-tags') || '').split(' ').filter(Boolean);
        const show = tag === 'all' || tags.includes(tag);
        post.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      if (noMatches) noMatches.classList.toggle('hidden', visible > 0);
    }

    filterBar.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest('[data-tag]') as HTMLElement | null;
      if (!btn) return;
      const tag = btn.getAttribute('data-tag') || 'all';
      applyFilter(tag);
      const url = tag === 'all' ? location.pathname : `${location.pathname}?tag=${encodeURIComponent(tag)}`;
      history.replaceState(null, '', url);
    });

    // Apply a filter passed via ?tag= (used by the clickable tag pills).
    const initial = new URLSearchParams(location.search).get('tag');
    if (initial && chips.some((c) => c.getAttribute('data-tag') === initial)) {
      applyFilter(initial);
    }
  }
</script>
