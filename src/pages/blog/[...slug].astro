---
import Base from '../../layouts/Base.astro';
import { readingTime } from '../../lib/readingTime';
import { getPublishedPosts, postPath, postOgPath } from '../../lib/content';
import { formatLongDate } from '../../lib/format';

export async function getStaticPaths() {
  const published = await getPublishedPosts();

  return published.map((post, i) => {
    const primaryTag = (post.data.tags ?? [])[0] ?? null;
    // published is already newest-first; filter preserves that order.
    const related = primaryTag
      ? published
          .filter(p => p.slug !== post.slug && (p.data.tags ?? []).includes(primaryTag))
          .slice(0, 3)
      : [];
    return {
      params: { slug: post.slug },
      props: {
        post,
        related,
        primaryTag,
        // published is newest-first, so i+1 is back in time.
        older: published[i + 1] ?? null,
        newer: published[i - 1] ?? null,
      },
    };
  });
}

const { post, related, primaryTag, older, newer } = Astro.props;
const { Content } = await post.render();

const dateFormatted = formatLongDate(post.data.date);
const updatedFormatted = post.data.updatedDate ? formatLongDate(post.data.updatedDate) : null;

// Pass raw title — Base.astro handles the suffix

const articleData = {
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  url: new URL(postPath(post.slug), Astro.site).href,
};

const ogImagePath = postOgPath(post.slug);
---

<Base title={post.data.title} description={post.data.description} article={articleData} ogImage={ogImagePath}>
  <!-- Intro -->
  <section class="mb-10 fade-in">
    <a href="/blog" class="text-xs text-muted-foreground uppercase tracking-wider hover:text-foreground transition-colors">← blog</a>
    <h1 class="text-2xl font-normal mt-4 mb-3 leading-relaxed">{post.data.title}</h1>
    <time class="text-xs text-muted-foreground uppercase tracking-wider">
      {dateFormatted}
    </time>
    <span class="text-xs text-muted-foreground uppercase tracking-wider"> · {readingTime(post.body)} min read</span>
    {updatedFormatted && (
      <p class="text-xs text-muted-foreground uppercase tracking-wider mt-1">updated {updatedFormatted}</p>
    )}
    {(post.data.tags ?? []).length > 0 && (
      <div class="flex flex-wrap gap-2 mt-4">
        {post.data.tags.map((tag) => (
          <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="text-[10px] uppercase tracking-wider text-muted-foreground border border-border rounded-full px-2 py-0.5 hover:text-foreground hover:border-foreground transition-colors">{tag}</a>
        ))}
      </div>
    )}
  </section>

  <!-- Content -->
  <article class="fade-in prose space-y-6 text-sm leading-relaxed">
    <Content />
  </article>

  {related.length > 0 && (
    <section class="mt-16 pt-8 border-t border-foreground/10 fade-in">
      <h2 class="text-xs text-muted-foreground uppercase tracking-wider mb-4">more on {primaryTag}</h2>
      <ul class="space-y-3">
        {related.map((r) => (
          <li>
            <a href={postPath(r.slug)} class="text-sm underline hover:no-underline">{r.data.title}</a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- Footer -->
  <footer class="mt-12 pt-8 border-t border-foreground/10 fade-in space-y-6">
    {(older || newer) && (
      <nav class="flex justify-between gap-6 text-sm" aria-label="Post navigation">
        {older ? (
          <a href={postPath(older.slug)} class="underline hover:no-underline text-muted-foreground hover:text-foreground transition-colors">← {older.data.title}</a>
        ) : <span />}
        {newer ? (
          <a href={postPath(newer.slug)} class="underline hover:no-underline text-muted-foreground hover:text-foreground transition-colors text-right">{newer.data.title} →</a>
        ) : <span />}
      </nav>
    )}
    <a href="/blog" class="block text-xs text-muted-foreground uppercase tracking-wider hover:text-foreground transition-colors">← all posts</a>
  </footer>
</Base>
