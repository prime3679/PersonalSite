---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';

const posts = [
  {
    slug: 'static-first-architecture',
    title: 'Why I Chose a Static-First Architecture',
    excerpt: 'Moving from database-driven to static-first: 10x faster, infinitely scalable, and $0 hosting costs.',
    date: '2025-11-05',
    tags: ['architecture', 'performance', 'web development'],
  },
  {
    slug: 'framer-motion-vs-css',
    title: 'Framer Motion vs CSS Animations: Why I Switched',
    excerpt: "CSS animations are great, but Framer Motion makes React apps feel magical. Here's why I made the switch.",
    date: '2025-11-04',
    tags: ['react', 'animations', 'ux'],
  },
];
---

<Base title="Blog">
  <Header />
  <main class="mx-auto max-w-3xl px-4 py-12 font-mono">
    <h1 class="text-2xl font-normal mb-12 uppercase tracking-wider fade-in">blog</h1>

    <div class="space-y-6">
      {posts.map((post) => (
        <article class="group border border-border rounded-xl p-6 transition-all duration-300 hover:border-foreground/30 fade-in">
          <a href={`/blog/${post.slug}`} class="block">
            <h2 class="text-lg font-normal mb-2 group-hover:text-foreground transition-colors">{post.title}</h2>
            <p class="text-sm leading-relaxed text-muted-foreground mb-4">{post.excerpt}</p>
            <div class="flex items-center justify-between text-xs text-muted-foreground">
              <time datetime={post.date}>
                {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <span class="group-hover:underline">read more →</span>
            </div>
          </a>
        </article>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-border fade-in">
      <p class="text-sm text-muted-foreground">
        more writing on <a href="https://minoritymusings.substack.com/?r=4evku&utm_campaign=pub-share-checklist" class="underline hover:no-underline" target="_blank" rel="noopener noreferrer">substack</a>.
      </p>
    </div>
  </main>
</Base>
