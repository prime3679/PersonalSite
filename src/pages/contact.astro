---
import Base from '../layouts/Base.astro';

// Formspree redirects here after a successful submit; ?sent=1 shows the banner.
const returnUrl = new URL('/contact?sent=1', Astro.site).href;

const socialLinks = [
  { label: 'linkedin', href: 'https://www.linkedin.com/in/adrianlumley/' },
  { label: 'github', href: 'https://github.com/prime3679' },
  { label: 'goodreads', href: 'https://www.goodreads.com/user/show/149439647-adrian-lumley' },
];
---

<Base title="contact" description="get in touch with adrian lumley: product leader, builder, occasional advisor.">
  <header class="page-header reveal">
    <h1 class="page-title">contact</h1>
    <p class="page-standfirst">always interested in product challenges, creative projects, or just good conversation. open to advisory roles and the right side-hustle.</p>
  </header>

  <div id="form-success" hidden class="card reveal mb-12" role="status">
    <p class="card-copy">message sent, thanks for reaching out. i'll get back to you soon.</p>
  </div>

  <form action="https://formspree.io/f/xjgewgoq" method="POST" class="content-stack reveal mb-16">
    <input type="text" name="_gotcha" style="display:none" />
    <input type="hidden" name="_next" value={returnUrl} />
    <div>
      <label for="name" class="field-label">name *</label>
      <input type="text" id="name" name="name" required class="field-input" placeholder="your name" />
    </div>
    <div>
      <label for="email" class="field-label">email *</label>
      <input type="email" id="email" name="email" required class="field-input" placeholder="your@email.com" />
    </div>
    <div>
      <label for="subject" class="field-label">subject</label>
      <input type="text" id="subject" name="subject" class="field-input" placeholder="what's this about?" />
    </div>
    <div>
      <label for="message" class="field-label">message *</label>
      <textarea id="message" name="message" required rows="5" class="field-input" placeholder="tell me about your project, idea, or just say hello."></textarea>
    </div>
    <button type="submit" class="button">send message</button>
  </form>

  <section class="reveal">
    <h2 class="section-title">elsewhere</h2>
    <p class="plain-links">
      {socialLinks.map((link, index) => (
        <><a class="touch-link" href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>{index < socialLinks.length - 1 && <span aria-hidden="true">·</span>}</>
      ))}
    </p>
  </section>
</Base>

<script>
  if (new URLSearchParams(location.search).has('sent')) {
    document.getElementById('form-success')?.removeAttribute('hidden');
  }
</script>
