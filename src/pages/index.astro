---
import Base from '../layouts/Base.astro';
import Panel from '../components/Panel.astro';
import LiveStatus from '../components/LiveStatus.astro';
import { getEpisodes } from '../lib/content';
import { padEpisode } from '../lib/format';

const episodes = await getEpisodes('desc');
const latestEpisodeNumber = episodes[0]?.data.episode ?? 0;
---

<Base description="director of product at salesforce. before that, disney+, siriusxm, and ea. building ai systems hands-on on a mac mini in nyc." ogImage="/og/home.png">
  <section class="reveal">
    <h1 class="hero-title">i build software that helps without getting in the way.</h1>
    <p class="hero-standfirst">
      director of product at salesforce. before that, disney+, siriusxm, and ea. but the work i care about most happens at home, on a mac mini running an agent i built myself.
    </p>

    <div class="pillars">
      <div>
        <h2 class="pillar-title">the work</h2>
        <p class="pillar-copy">products at real scale, with the numbers attached.</p>
        <a class="touch-link" href="/work">see the work</a>
      </div>
      <div>
        <h2 class="pillar-title">the building</h2>
        <p class="pillar-copy">rogue: an agent i built. runs my ops, made this site. live.</p>
        <a class="touch-link" href="/lab">open the lab</a>
      </div>
      <div>
        <h2 class="pillar-title">the thinking</h2>
        <p class="pillar-copy">writing on ai and enterprise, plus a fiction serial.</p>
        <a class="touch-link" href="/signal-room">read signal room</a>
      </div>
    </div>

    <Panel id="instrument-strip" ariaLabel="rogue status" label="rogue · status" class="mb-8">
      <p class="flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-xs text-[var(--panel-soft)]">
        <LiveStatus />
        <span aria-hidden="true">·</span>
        <span>signal room ep {padEpisode(latestEpisodeNumber)} live</span>
      </p>
    </Panel>

    <div class="cta-row">
      <span class="cta-copy">building something in ai? i'd like to hear about it.</span>
      <span class="plain-links" aria-label="contact links">
        <a class="touch-link" href="/contact">email</a><span aria-hidden="true">·</span>
        <a class="touch-link" href="https://www.linkedin.com/in/adrianlumley/" target="_blank" rel="noopener noreferrer">linkedin</a><span aria-hidden="true">·</span>
        <a class="touch-link" href="https://github.com/prime3679" target="_blank" rel="noopener noreferrer">github</a>
      </span>
    </div>
  </section>
</Base>
