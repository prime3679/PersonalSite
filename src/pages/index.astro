---
import Base from '../layouts/Base.astro';
import { now } from '../data/now';
import { labProjects, type LabProject } from '../data/lab';

const featuredProjects = ['agent-arcade', 'bishop', 'mission-control', 'operator-stack']
  .map((id) => labProjects.find((project) => project.id === id))
  .filter((project): project is LabProject => Boolean(project));

const updatedLabel = 'June 2026';
---

<Base
  description="Director of Product at Salesforce, building at the intersection of AI and enterprise. Previously SiriusXM, Disney+, EA. Based in NYC."
  ogImage="/og/home.png"
  mainClass="site-shell py-10 sm:py-14"
>

    <section class="fade-in">
      <p class="mb-5 text-[0.72rem] uppercase tracking-[0.2em] text-muted-foreground">
        adrian@nyc:~$ whoami --public
      </p>
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1.15fr),minmax(18rem,0.85fr)] lg:items-start">
        <div>
          <h1 class="max-w-[12ch] text-[clamp(2.6rem,7vw,5.2rem)] font-semibold lowercase leading-[0.96] tracking-[-0.06em] text-foreground">
            a personal operating system, run in public.
          </h1>
          <div class="mt-6 max-w-3xl space-y-4 text-[1rem] leading-8 text-foreground/78 sm:text-[1.05rem]">
            <p>
              director of product at <a href="https://www.salesforce.com" class="console-link" target="_blank" rel="noopener noreferrer">salesforce</a>,
              working at the intersection of ai and enterprise: how large organizations actually adopt new technology, and what it takes to make it stick.
            </p>
            <p class="text-muted-foreground">
              14 years in tech. previously siriusxm, disney+, ea. the rest of this site is the off-hours system: public notes, small products, and agent experiments that are safe to show in the open.
            </p>
          </div>
        </div>

        <aside class="console-panel overflow-hidden rounded-lg">
          <div class="border-b border-border px-5 py-4">
            <p class="console-label">runtime</p>
          </div>
          <div class="bg-[hsl(var(--panel-strong))]">
            <div class="console-kv">
              <span class="console-k">updated</span>
              <span class="console-v">{updatedLabel}</span>
            </div>
            <div class="console-kv">
              <span class="console-k">stack</span>
              <span class="console-v">astro, typescript, node.js, claude</span>
            </div>
            <div class="console-kv">
              <span class="console-k">base</span>
              <span class="console-v">nyc / eastern time / one mac mini and a lot of opinions</span>
            </div>
            <div class="console-kv">
              <span class="console-k">status</span>
              <span class="console-v"><span class="mr-2 inline-block align-middle text-[hsl(var(--success))]">●</span>operational</span>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="mt-10 fade-in">
      <div class="console-grid lg:grid-cols-[minmax(0,1fr),minmax(0,1fr)]">
        <div class="console-panel">
          <div class="border-b border-border px-5 py-4">
            <div class="flex items-center justify-between gap-4">
              <p class="console-label">currently</p>
              <span class="text-[0.72rem] uppercase tracking-[0.18em] text-muted-foreground">{updatedLabel}</span>
            </div>
          </div>
          <div class="bg-[hsl(var(--panel-strong))]">
            {now.building.map((item) => (
              <div class="console-kv">
                <span class="console-k">building</span>
                <p class="console-v">
                  {item.href && item.label && (
                    <>
                      <a href={item.href} class="console-link">{item.label}</a>
                      {' — '}
                    </>
                  )}
                  {item.text}
                </p>
              </div>
            ))}
            <div class="console-kv">
              <span class="console-k">reading</span>
              <p class="console-v">
                {now.reading.map((book) => book.author).join(' · ')}
                {' · '}
                <a href={now.goodreads} class="console-link" target="_blank" rel="noopener noreferrer">goodreads</a>
              </p>
            </div>
            <div class="console-kv">
              <span class="console-k">training</span>
              <p class="console-v">{now.training.disciplines.join(' + ')}. {now.training.note}</p>
            </div>
          </div>
        </div>

        <div class="console-panel">
          <div class="border-b border-border px-5 py-4">
            <div class="flex items-center justify-between gap-4">
              <p class="console-label">channels</p>
              <span class="text-[0.72rem] uppercase tracking-[0.18em] text-muted-foreground">next hops</span>
            </div>
          </div>
          <div class="grid gap-px bg-border">
            <a href="/lab" class="flex items-center justify-between bg-[hsl(var(--panel-strong))] px-5 py-4 hover:bg-[hsl(var(--panel))]">
              <span>inspect live processes</span>
              <span class="text-[hsl(var(--accent))]">~/lab</span>
            </a>
            <a href="/work" class="flex items-center justify-between bg-[hsl(var(--panel-strong))] px-5 py-4 hover:bg-[hsl(var(--panel))]">
              <span>see the work</span>
              <span class="text-[hsl(var(--accent))]">~/work</span>
            </a>
            <a href="/operator-stack" class="flex items-center justify-between bg-[hsl(var(--panel-strong))] px-5 py-4 hover:bg-[hsl(var(--panel))]">
              <span>browse operator tools</span>
              <span class="text-[hsl(var(--accent))]">~/operator-stack</span>
            </a>
            <a href="/contact" class="flex items-center justify-between bg-[hsl(var(--panel-strong))] px-5 py-4 hover:bg-[hsl(var(--panel))]">
              <span>open a channel</span>
              <span class="text-[hsl(var(--accent))]">~/contact</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-16 fade-in" id="lab-preview">
      <div class="mb-6 flex items-end justify-between gap-4 border-b border-border pb-4">
        <div>
          <p class="console-label mb-2">featured processes</p>
          <h2 class="text-2xl lowercase tracking-[-0.03em]">what is running in public</h2>
        </div>
        <a href="/lab" class="console-link text-sm lowercase">full process list</a>
      </div>

      <div class="space-y-4">
        {featuredProjects.map((project) => (
          <article class="process-card">
            <div class="process-dot" data-tone={project.badge.tone}></div>
            <div>
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  {project.external ? (
                    <a href={project.href} target="_blank" rel="noopener noreferrer" class="text-xl lowercase tracking-[-0.02em] hover:text-[hsl(var(--accent))]">{project.title}</a>
                  ) : (
                    <a href={project.href} class="text-xl lowercase tracking-[-0.02em] hover:text-[hsl(var(--accent))]">{project.title}</a>
                  )}
                  <p class="mt-1 text-[0.72rem] uppercase tracking-[0.18em] text-muted-foreground">{project.dateline}</p>
                </div>
                <span class="console-chip" data-state={project.badge.tone}>{project.badge.label}</span>
              </div>

              <p class="mt-3 max-w-3xl text-sm leading-7 text-foreground/78">{project.description}</p>

              <div class="mt-4 flex flex-wrap gap-2">
                {project.stats.map((stat) => (
                  <span class="telemetry-pill">
                    <strong>{stat.value}</strong>
                    <span>{stat.label}</span>
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
</Base>
