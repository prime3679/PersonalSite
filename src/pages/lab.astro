---
import Base from '../layouts/Base.astro';
import { labProjects, type LabProject } from '../data/lab';
import { getEpisodes } from '../lib/content';
import { padEpisode, snapshotLabel } from '../lib/format';
import familyosStats from '../../public/familyos-stats.json';
import bishopStats from '../../public/bishop-stats.json';

// Stats render at build time from the repo JSONs (the cron commits them, which
// triggers a deploy anyway) — honest snapshot labels instead of client fetches.
const episodes = await getEpisodes();
const latest = episodes[0];

const overrides: Record<string, Partial<LabProject>> = {
  'signal-room': {
    stats: [
      { value: padEpisode(episodes.length), label: 'episodes' },
      { value: latest?.data.title ?? '—', label: 'latest signal' },
      { value: 'weekly', label: 'cadence' },
    ],
  },
  familyos: {
    stats: [
      { value: String(familyosStats.weeksRunning ?? '—'), label: 'weeks running' },
      { value: String(familyosStats.proposalsSent ?? '—'), label: 'proposals sent' },
      {
        value:
          familyosStats.approvalRate != null
            ? `${Math.round(familyosStats.approvalRate * 100)}%`
            : 'pending',
        label: 'approval rate',
      },
    ],
    statsNote: `snapshot · ${snapshotLabel(familyosStats.updatedAt)}`,
  },
  bishop: {
    stats: [
      { value: String(bishopStats.daysRunning ?? '—'), label: 'days running' },
      { value: String(bishopStats.cronCount ?? '—'), label: 'cron jobs' },
      { value: bishopStats.uptime ?? '24/7', label: 'uptime' },
    ],
    statsNote: `snapshot · ${snapshotLabel(bishopStats.updatedAt)}`,
  },
};

const projects = labProjects.map((project) =>
  overrides[project.id] ? { ...project, ...overrides[project.id] } : project,
);

const categoryOrder = ['agents', 'tools', 'toys', 'writing'] as const;
const categoryLabels = {
  agents: 'agent lane',
  tools: 'tool lane',
  toys: 'toy lane',
  writing: 'writing lane',
} as const;
---

<Base
  title="Lab — Adrian Lumley"
  description="Things I'm building. Some finished, some running, some still figuring out."
  mainClass="site-shell py-10 sm:py-14"
>

    <section class="fade-in">
      <p class="mb-5 text-[0.72rem] uppercase tracking-[0.2em] text-muted-foreground">
        adrian@nyc:~/lab$ ps --public --grouped
      </p>
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.15fr),minmax(18rem,0.85fr)] lg:items-start">
        <div>
          <h1 class="text-[clamp(2.4rem,6vw,4.4rem)] font-semibold lowercase tracking-[-0.05em] text-foreground">
            lab
          </h1>
          <p class="mt-4 max-w-3xl text-[1rem] leading-8 text-foreground/78 sm:text-[1.05rem]">
            things i am building. not a portfolio, not a launch queue. this is the public process table:
            what is running, what is paused, what is safe to click, and what learned something even if it never became a company.
          </p>
        </div>

        <aside class="console-panel overflow-hidden rounded-lg">
          <div class="border-b border-border px-5 py-4">
            <p class="console-label">operator notes</p>
          </div>
          <div class="space-y-0 bg-[hsl(var(--panel-strong))] text-sm">
            <div class="console-kv">
              <span class="console-k">scope</span>
              <span class="console-v">{projects.length} public projects</span>
            </div>
            <div class="console-kv">
              <span class="console-k">feed</span>
              <span class="console-v">stats are baked at build time when public snapshots exist</span>
            </div>
            <div class="console-kv">
              <span class="console-k">rule</span>
              <span class="console-v">no private dashboards, credentials, or internal-only specifics</span>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="mt-10 fade-in">
      <div class="flex flex-wrap gap-2" id="lab-filters" role="group" aria-label="Filter projects by kind">
        <button type="button" class="chip" data-filter="all" aria-pressed="true">all</button>
        <button type="button" class="chip" data-filter="agents" aria-pressed="false">agents</button>
        <button type="button" class="chip" data-filter="tools" aria-pressed="false">tools</button>
        <button type="button" class="chip" data-filter="toys" aria-pressed="false">toys</button>
        <button type="button" class="chip" data-filter="writing" aria-pressed="false">writing</button>
      </div>
    </section>

    <section class="mt-10 space-y-10 fade-in">
      {categoryOrder.map((category) => (
        <section data-group={category} class="space-y-4">
          <div class="flex items-center gap-4 border-b border-border pb-3">
            <p class="console-label">{categoryLabels[category]}</p>
            <span class="text-xs uppercase tracking-[0.16em] text-muted-foreground">
              {projects.filter((project) => project.category === category).length} entries
            </span>
          </div>

          <div class="space-y-4">
            {projects.filter((project) => project.category === category).map((project) => (
              <article
                class="process-card"
                id={project.id}
                data-category={project.category}
              >
                <div class="process-dot" data-tone={project.badge.tone}></div>
                <div>
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div>
                      {project.external ? (
                        <a href={project.href} target="_blank" rel="noopener noreferrer" class="text-xl lowercase tracking-[-0.02em] hover:text-[hsl(var(--accent))]">{project.title}</a>
                      ) : (
                        <a href={project.href} class="text-xl lowercase tracking-[-0.02em] hover:text-[hsl(var(--accent))]">{project.title}</a>
                      )}
                      <p class="mt-1 text-[0.72rem] uppercase tracking-[0.18em] text-muted-foreground">{project.dateline}</p>
                    </div>

                    <span class="console-chip" data-state={project.badge.tone}>
                      {project.badge.label}
                    </span>
                  </div>

                  <p class="mt-3 max-w-3xl text-sm leading-7 text-foreground/78">{project.description}</p>

                  <div class="mt-4 flex flex-wrap gap-2">
                    {project.stats.map((stat) => (
                      <span class="telemetry-pill">
                        <strong>{stat.value}</strong>
                        <span>{stat.label}</span>
                      </span>
                    ))}
                  </div>

                  {project.statsNote && (
                    <p class="mt-3 text-[0.68rem] uppercase tracking-[0.16em] text-muted-foreground">
                      {project.statsNote}
                    </p>
                  )}

                  <div class="mt-4 flex flex-wrap gap-4 text-sm">
                    {project.links.map((link) =>
                      link.external ? (
                        <a href={link.href} target="_blank" rel="noopener noreferrer" class="console-link">{link.label}</a>
                      ) : (
                        <a href={link.href} class="console-link">{link.label}</a>
                      ),
                    )}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}

      <div class="rounded-lg border border-dashed border-border px-5 py-5 text-sm text-muted-foreground">
        more processes will appear when they are safe to show and worth keeping online.
      </div>
    </section>
</Base>

<script>
  const labFilters = document.getElementById('lab-filters');

  if (labFilters) {
    const chips = Array.from(labFilters.querySelectorAll('[data-filter]'));
    const cards = Array.from(document.querySelectorAll('[data-category]'));
    const groups = Array.from(document.querySelectorAll('[data-group]'));

    labFilters.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      const button = target.closest('[data-filter]') as HTMLElement | null;
      if (!button) return;

      const filter = button.dataset.filter;
      chips.forEach((chip) => chip.setAttribute('aria-pressed', String(chip === button)));

      cards.forEach((card) => {
        const show = filter === 'all' || card.getAttribute('data-category') === filter;
        card.classList.toggle('hidden', !show);
      });

      groups.forEach((group) => {
        const category = group.getAttribute('data-group');
        const visibleCards = cards.filter(
          (card) => card.getAttribute('data-category') === category && !card.classList.contains('hidden'),
        );
        group.classList.toggle('hidden', visibleCards.length === 0);
      });
    });
  }
</script>
