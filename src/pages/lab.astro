---
import Base from '../layouts/Base.astro';
import PageIntro from '../components/PageIntro.astro';
import { ROGUE_EPOCH } from '../data/rogue';

const rogueSince = new Date(`${ROGUE_EPOCH}T00:00:00Z`)
  .toLocaleString('en-US', { month: 'long', year: 'numeric', timeZone: 'UTC' })
  .toLowerCase();
const toys = [
  { label: 'the cap is gone', href: '/lab/the-cap-is-gone/' },
  { label: 'the crazy wall', href: '/lab/crazy-wall/' },
  { label: 'fable field recorder', href: '/lab/fable-field-recorder/' },
  { label: 'iron log', href: '/lab/iron-log/' },
  { label: 'joytap', href: '/writing/joytap-one-sprint' },
  { label: "my kid's world", href: '/lab/my-kids-world/' },
  { label: 'chaos garden', href: '/lab/chaos-garden/' },
  { label: 'meeting price tag', href: '/lab/meeting-cost/' },
];
const metaLabel = 'font-mono text-xs tracking-[.08em] text-[var(--ink-soft)]';
---

<Base title="lab" description="things i'm building. not a portfolio, an honest record of what's running and what survived contact with reality.">
  <PageIntro title="lab" standfirst="things i'm building. not a portfolio, an honest record of what's running, what's in progress, and what didn't survive contact with reality." />

  <section class="reveal" id="rogue">
    <p class={metaLabel}>flagship</p>
    <h2 class="lab-lede mt-2">rogue</h2>
    <p class="ui-copy mt-4" style="max-width:var(--measure)">the agent i actually use. lives on a mac mini, wired to claude and codex, runs the ops i used to do by hand, and builds things, this site included. signal room is fiction about a system like it.</p>
    <p class="body-copy mt-3 italic" style="max-width:var(--measure)">i ran a stack of agents and kept the combination that worked.</p>
    <p class="body-copy mt-3 text-[var(--ink-soft)]" style="max-width:var(--measure)">running since {rogueSince}, not as a demo but as the local system i keep using.</p>
    <p class="plain-links mt-5"><a href="/signal-room">read signal room</a></p>
  </section>

  <section class="reveal rule-top mt-16 pt-16" id="past-the-pilot">
    <p class={metaLabel}>project</p>
    <h2 class="card-title mt-2">past the pilot</h2>
    <p class="ui-copy mt-3" style="max-width:var(--measure)">a public evidence ledger for enterprise ai that made it into real work. 25 named systems, 74 sources, and every claim tied to a receipt.</p>
    <p class="plain-links mt-4"><a href="https://pastthepilot.adrianlumley.co">open the ledger</a></p>
  </section>

  <section class="reveal rule-top mt-16 pt-16" id="fork">
    <p class={metaLabel}>toy</p>
    <h2 class="card-title mt-2">fork</h2>
    <p class="ui-copy mt-3" style="max-width:var(--measure)">one hard decision, three futures, three marks each. fork draws them as one map, in ink and pencil, and hands the decision back. no account, no ai, nothing leaves the page.</p>
    <p class="plain-links mt-4"><a href="/lab/fork/">open</a></p>
  </section>

  <section class="reveal rule-top mt-16 pt-16" id="ink-field">
    <p class={metaLabel}>toy</p>
    <h2 class="card-title mt-2">ink field</h2>
    <p class="ui-copy mt-3" style="max-width:var(--measure)">a living sumi-e study. sumi ink pours onto warm bone paper and drifts through a seeded noise field, with rare embers of clay. tap the paper to pour, then save the print. it runs on nothing but a single html file.</p>
    <p class="plain-links mt-4">
      <a href="/lab/ink-field/">open</a>
      <span aria-hidden="true">·</span>
      <a href="https://github.com/prime3679/ink-field">source</a>
    </p>
  </section>

  <section class="reveal rule-top mt-16 pt-16" id="also-built">
    <h2 class="section-title">also built</h2>
    <p class="plain-links">
      {toys.map((toy, index) => (
        <>
          <a href={toy.href}>{toy.label}</a>
          {index < toys.length - 1 && <span aria-hidden="true">·</span>}
        </>
      ))}
    </p>
  </section>

  <section class="reveal rule-top mt-16 pt-16" id="feedback-gate">
    <p class={metaLabel}>feedback</p>
    <p class="body-copy mt-3" style="max-width:var(--measure)">the claim of this page is simple: i can turn ambiguity into a working personal operating system with taste, restraint, and receipts.</p>
    <p class="ui-copy mt-3" style="max-width:var(--measure)">the question worth answering is not whether the page is impressive. it is what the page makes you trust me to build.</p>
    <p class="plain-links mt-5">
      <a href="/contact">send the sentence</a>
      <span aria-hidden="true">·</span>
      <span>what did this make you believe i am good at?</span>
    </p>
  </section>
</Base>
