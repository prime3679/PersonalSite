---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
---

<Base
  title="Lab — Adrian Lumley"
  description="Things I'm building. Some finished, some running, some still figuring out."
>
  <Header />
  <main class="mx-auto max-w-2xl px-6 py-12 font-mono">

    <!-- Header -->
    <section class="mb-12 fade-in">
      <h1 class="text-2xl font-normal mb-3">lab</h1>
      <p class="text-sm leading-relaxed text-foreground/60">
        things i'm building. not a portfolio — an honest record of what's running,
        what's in progress, and what didn't survive contact with reality.
      </p>
    </section>

    <!-- Projects -->
    <section class="space-y-4 fade-in">

      <!-- Signal Room -->
      <article class="border border-foreground/10 rounded-xl overflow-hidden" id="signal-room">
        <div class="p-6">
          <div class="flex items-start justify-between mb-3">
            <div>
              <a href="/signal-room/" class="text-base font-medium hover:underline">signal room</a>
              <p class="text-xs text-muted-foreground mt-0.5">fiction serial · may 2026</p>
            </div>
            <span class="text-xs px-2 py-0.5 rounded border border-sky-500/30 text-sky-600 dark:text-sky-400 bg-sky-500/5 shrink-0 ml-4">
              public
            </span>
          </div>
          <p class="text-sm leading-relaxed text-foreground/70 mb-4">
            a public home for the rogue/bishop fiction serial: literary fragments about systems,
            households, truth, and mercy. readable without knowing the private machinery underneath.
          </p>

          <div class="border-t border-foreground/5 pt-4 mt-4">
            <div class="grid grid-cols-3 gap-4 text-center">
              <div>
                <div class="text-lg font-medium">01</div>
                <div class="text-xs text-muted-foreground mt-0.5">episode</div>
              </div>
              <div>
                <div class="text-lg font-medium">Night Shift</div>
                <div class="text-xs text-muted-foreground mt-0.5">first signal</div>
              </div>
              <div>
                <div class="text-lg font-medium">0 deps</div>
                <div class="text-xs text-muted-foreground mt-0.5">plain html</div>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-4 mt-4 pt-4 border-t border-foreground/5">
            <a href="/signal-room/" class="text-xs underline hover:no-underline text-muted-foreground">read episode 01 ↗</a>
          </div>
        </div>
      </article>

      <!-- Operator Stack -->
      <article class="border border-foreground/10 rounded-xl overflow-hidden" id="operator-stack">
        <div class="p-6">
          <div class="flex items-start justify-between mb-3">
            <div>
              <a href="/operator-stack" class="text-base font-medium hover:underline">operator stack</a>
              <p class="text-xs text-muted-foreground mt-0.5">built april 2026</p>
            </div>
            <span class="status-badge text-xs px-2 py-0.5 rounded border border-emerald-500/30 text-emerald-600 dark:text-emerald-400 bg-emerald-500/5 shrink-0 ml-4">
              active
            </span>
          </div>
          <p class="text-sm leading-relaxed text-foreground/70 mb-4">
            a small stack of operator tools for people carrying too many threads. morning brief,
            weekly review, and a fuller morning operator layer. priced low on purpose. built to be useful fast.
          </p>

          <div class="border-t border-foreground/5 pt-4 mt-4">
            <div class="grid grid-cols-3 gap-4 text-center">
              <div>
                <div class="text-lg font-medium">3</div>
                <div class="text-xs text-muted-foreground mt-0.5">live products</div>
              </div>
              <div>
                <div class="text-lg font-medium">1</div>
                <div class="text-xs text-muted-foreground mt-0.5">local draft</div>
              </div>
              <div>
                <div class="text-lg font-medium">$3–$9</div>
                <div class="text-xs text-muted-foreground mt-0.5">current ladder</div>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-4 mt-4 pt-4 border-t border-foreground/5">
            <a href="/operator-stack" class="text-xs underline hover:no-underline text-muted-foreground">browse tools ↗</a>
          </div>
        </div>
      </article>

      <!-- 90-Day OS -->
      <article class="border border-foreground/10 rounded-xl overflow-hidden" id="90-day-os">
        <div class="p-6">
          <div class="flex items-start justify-between mb-3">
            <div>
              <a href="/90-day-os" class="text-base font-medium hover:underline">90-day os</a>
              <p class="text-xs text-muted-foreground mt-0.5">built march 2026</p>
            </div>
            <span class="status-badge text-xs px-2 py-0.5 rounded border border-emerald-500/30 text-emerald-600 dark:text-emerald-400 bg-emerald-500/5 shrink-0 ml-4">
              active
            </span>
          </div>
          <p class="text-sm leading-relaxed text-foreground/70 mb-4">
            a simple 90-day operating system for identity, goals, habit replacement, daily check-ins,
            dashboard reset, and weekly review. built as a concrete way to run a quarter on purpose
            instead of letting it dissolve into reactive weeks.
          </p>

          <div class="border-t border-foreground/5 pt-4 mt-4">
            <div class="grid grid-cols-3 gap-4 text-center">
              <div>
                <div class="text-lg font-medium">90</div>
                <div class="text-xs text-muted-foreground mt-0.5">day cycle</div>
              </div>
              <div>
                <div class="text-lg font-medium">8</div>
                <div class="text-xs text-muted-foreground mt-0.5">core sections</div>
              </div>
              <div>
                <div class="text-lg font-medium">mvp</div>
                <div class="text-xs text-muted-foreground mt-0.5">review-ready</div>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-4 mt-4 pt-4 border-t border-foreground/5">
            <a href="/90-day-os" class="text-xs underline hover:no-underline text-muted-foreground">open app ↗</a>
          </div>
        </div>
      </article>

      <!-- FamilyOS -->
      <article class="border border-foreground/10 rounded-xl overflow-hidden" id="familyos">
        <div class="p-6">
          <div class="flex items-start justify-between mb-3">
            <div>
              <a href="/familyos" class="text-base font-medium hover:underline">familyos</a>
              <p class="text-xs text-muted-foreground mt-0.5">started feb 2026</p>
            </div>
            <span class="status-badge text-xs px-2 py-0.5 rounded border border-emerald-500/30 text-emerald-600 dark:text-emerald-400 bg-emerald-500/5 shrink-0 ml-4">
              active
            </span>
          </div>
          <p class="text-sm leading-relaxed text-foreground/70 mb-4">
            multi-agent family coordination. scans the week's calendar every monday,
            proposes assignments, learns from approvals. built because two working
            partners with a child deserve better than group texts and spreadsheets.
          </p>

          <!-- Live Stats -->
          <div id="familyos-stats" class="border-t border-foreground/5 pt-4 mt-4">
            <div class="grid grid-cols-3 gap-4 text-center" id="familyos-stats-loaded" style="display:none">
              <div>
                <div class="text-lg font-medium tabular-nums" id="stat-weeks">—</div>
                <div class="text-xs text-muted-foreground mt-0.5">weeks running</div>
              </div>
              <div>
                <div class="text-lg font-medium tabular-nums" id="stat-proposals">—</div>
                <div class="text-xs text-muted-foreground mt-0.5">proposals sent</div>
              </div>
              <div>
                <div class="text-lg font-medium tabular-nums" id="stat-approval">—</div>
                <div class="text-xs text-muted-foreground mt-0.5">approval rate</div>
              </div>
            </div>
            <div id="familyos-stats-loading" class="text-xs text-muted-foreground">
              loading stats...
            </div>
          </div>

          <div class="flex items-center gap-4 mt-4 pt-4 border-t border-foreground/5">
            <a href="/familyos" class="text-xs underline hover:no-underline text-muted-foreground">details ↗</a>
            <a href="https://github.com/prime3679/familyos-template" target="_blank" rel="noopener noreferrer" class="text-xs underline hover:no-underline text-muted-foreground">open source ↗</a>
          </div>
        </div>
      </article>

      <!-- Bishop -->
      <article class="border border-foreground/10 rounded-xl overflow-hidden" id="bishop">
        <div class="p-6">
          <div class="flex items-start justify-between mb-3">
            <div>
              <a href="/bishop-development" class="text-base font-medium hover:underline">bishop</a>
              <p class="text-xs text-muted-foreground mt-0.5">started feb 2026</p>
            </div>
            <span class="text-xs px-2 py-0.5 rounded border border-emerald-500/30 text-emerald-600 dark:text-emerald-400 bg-emerald-500/5 shrink-0 ml-4">
              active
            </span>
          </div>
          <p class="text-sm leading-relaxed text-foreground/70 mb-4">
            ai chief of staff. runs on a mac mini, connected to calendar, email, and github.
            handles morning briefings, monitors systems, drafts artifacts, and builds things
            like this while i'm at work. the goal is to see how much a single agent can own.
          </p>

          <!-- Live Stats -->
          <div class="border-t border-foreground/5 pt-4 mt-4">
            <div class="grid grid-cols-3 gap-4 text-center">
              <div>
                <div class="text-lg font-medium tabular-nums" id="bishop-stat-days">—</div>
                <div class="text-xs text-muted-foreground mt-0.5">days running</div>
              </div>
              <div>
                <div class="text-lg font-medium tabular-nums" id="bishop-stat-crons">—</div>
                <div class="text-xs text-muted-foreground mt-0.5">cron jobs</div>
              </div>
              <div>
                <div class="text-lg font-medium tabular-nums">24/7</div>
                <div class="text-xs text-muted-foreground mt-0.5">uptime</div>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-4 mt-4 pt-4 border-t border-foreground/5">
            <a href="/bishop-development" class="text-xs underline hover:no-underline text-muted-foreground">details ↗</a>
          </div>
        </div>
      </article>

      <!-- Mission Control -->
      <article class="border border-foreground/10 rounded-xl overflow-hidden" id="mission-control">
        <div class="p-6">
          <div class="flex items-start justify-between mb-3">
            <div>
              <a href="https://mission.adrianlumley.co" target="_blank" rel="noopener noreferrer" class="text-base font-medium hover:underline">mission control</a>
              <p class="text-xs text-muted-foreground mt-0.5">started feb 2026</p>
            </div>
            <span class="text-xs px-2 py-0.5 rounded border border-emerald-500/30 text-emerald-600 dark:text-emerald-400 bg-emerald-500/5 shrink-0 ml-4">
              active
            </span>
          </div>
          <p class="text-sm leading-relaxed text-foreground/70 mb-4">
            personal ops dashboard. spend tracking, provider health, cron status, git activity,
            and security alerts — all in one tab. runs on the mac mini behind a cloudflare tunnel.
          </p>

          <div class="border-t border-foreground/5 pt-4 mt-4">
            <div class="grid grid-cols-3 gap-4 text-center">
              <div>
                <div class="text-lg font-medium">port 7777</div>
                <div class="text-xs text-muted-foreground mt-0.5">local</div>
              </div>
              <div>
                <div class="text-lg font-medium">cloudflare</div>
                <div class="text-xs text-muted-foreground mt-0.5">tunnel</div>
              </div>
              <div>
                <div class="text-lg font-medium">live</div>
                <div class="text-xs text-muted-foreground mt-0.5">always on</div>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-4 mt-4 pt-4 border-t border-foreground/5">
            <a href="https://mission.adrianlumley.co" target="_blank" rel="noopener noreferrer" class="text-xs underline hover:no-underline text-muted-foreground">open dashboard ↗</a>
          </div>
        </div>
      </article>

      <!-- Bishop Bench -->
      <article class="border border-foreground/10 rounded-xl overflow-hidden" id="bishop-bench">
        <div class="p-6">
          <div class="flex items-start justify-between mb-3">
            <div>
              <a href="https://github.com/prime3679/bishop-bench" target="_blank" rel="noopener noreferrer" class="text-base font-medium hover:underline">bishop-bench</a>
              <p class="text-xs text-muted-foreground mt-0.5">started feb 2026</p>
            </div>
            <span class="text-xs px-2 py-0.5 rounded border border-amber-500/30 text-amber-600 dark:text-amber-400 bg-amber-500/5 shrink-0 ml-4">
              experimental
            </span>
          </div>
          <p class="text-sm leading-relaxed text-foreground/70 mb-4">
            multi-model eval runner. tests the same task across claude, gpt, and gemini simultaneously
            and scores outputs side-by-side. built to validate the cost routing architecture — 
            if haiku can do the job, there's no reason to pay for opus.
          </p>

          <div class="border-t border-foreground/5 pt-4 mt-4">
            <div class="grid grid-cols-3 gap-4 text-center">
              <div>
                <div class="text-lg font-medium">4</div>
                <div class="text-xs text-muted-foreground mt-0.5">models tested</div>
              </div>
              <div>
                <div class="text-lg font-medium">40x</div>
                <div class="text-xs text-muted-foreground mt-0.5">cost delta (haiku→opus)</div>
              </div>
              <div>
                <div class="text-lg font-medium">real</div>
                <div class="text-xs text-muted-foreground mt-0.5">api calls</div>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-4 mt-4 pt-4 border-t border-foreground/5">
            <a href="https://github.com/prime3679/bishop-bench" target="_blank" rel="noopener noreferrer" class="text-xs underline hover:no-underline text-muted-foreground">github ↗</a>
          </div>
        </div>
      </article>

      <!-- FamilyOS Template -->
      <article class="border border-foreground/10 rounded-xl overflow-hidden" id="familyos-template">
        <div class="p-6">
          <div class="flex items-start justify-between mb-3">
            <div>
              <a href="https://github.com/prime3679/familyos-template" target="_blank" rel="noopener noreferrer" class="text-base font-medium hover:underline">familyos-template</a>
              <p class="text-xs text-muted-foreground mt-0.5">open source · feb 2026</p>
            </div>
            <span class="text-xs px-2 py-0.5 rounded border border-sky-500/30 text-sky-600 dark:text-sky-400 bg-sky-500/5 shrink-0 ml-4">
              open source
            </span>
          </div>
          <p class="text-sm leading-relaxed text-foreground/70 mb-4">
            the generic, self-hostable version of familyos. no saas, no subscription.
            runs on your own machine with a telegram bot, google calendar, and an anthropic api key.
            configure your schedule, point it at your family's calendars, and let it run.
          </p>

          <div class="border-t border-foreground/5 pt-4 mt-4">
            <div class="grid grid-cols-3 gap-4 text-center">
              <div>
                <div class="text-lg font-medium">node.js</div>
                <div class="text-xs text-muted-foreground mt-0.5">runtime</div>
              </div>
              <div>
                <div class="text-lg font-medium">sqlite</div>
                <div class="text-xs text-muted-foreground mt-0.5">storage</div>
              </div>
              <div>
                <div class="text-lg font-medium">mit</div>
                <div class="text-xs text-muted-foreground mt-0.5">license</div>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-4 mt-4 pt-4 border-t border-foreground/5">
            <a href="https://github.com/prime3679/familyos-template" target="_blank" rel="noopener noreferrer" class="text-xs underline hover:no-underline text-muted-foreground">github ↗</a>
            <a href="/blog/familyos-building-a-family-agent" class="text-xs underline hover:no-underline text-muted-foreground">read the story ↗</a>
          </div>
        </div>
      </article>

      <!-- Evelyn's World -->
      <article class="border border-foreground/10 rounded-xl overflow-hidden" id="evelyns-world">
        <div class="p-6">
          <div class="flex items-start justify-between mb-3">
            <div>
              <a href="/lab/evelyns-world/" class="text-base font-medium hover:underline">evelyn's world</a>
              <p class="text-xs text-muted-foreground mt-0.5">built april 2026</p>
            </div>
            <span class="text-xs px-2 py-0.5 rounded border border-emerald-500/30 text-emerald-600 dark:text-emerald-400 bg-emerald-500/5 shrink-0 ml-4">
              new
            </span>
          </div>
          <p class="text-sm leading-relaxed text-foreground/70 mb-4">
            a warm little animal garden for toddler play. nine bold cards lead the page, first tap plays the
            animal sound, second tap speaks the name, and a gentle “where is it?” game adds a cheerful win.
          </p>

          <div class="border-t border-foreground/5 pt-4 mt-4">
            <div class="grid grid-cols-3 gap-4 text-center">
              <div>
                <div class="text-lg font-medium">9</div>
                <div class="text-xs text-muted-foreground mt-0.5">animal cards</div>
              </div>
              <div>
                <div class="text-lg font-medium">tap x2</div>
                <div class="text-xs text-muted-foreground mt-0.5">sound then speech</div>
              </div>
              <div>
                <div class="text-lg font-medium">0 deps</div>
                <div class="text-xs text-muted-foreground mt-0.5">pure html/js</div>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-4 mt-4 pt-4 border-t border-foreground/5">
            <a href="/lab/evelyns-world/" class="text-xs underline hover:no-underline text-muted-foreground">open app ↗</a>
          </div>
        </div>
      </article>

      <!-- Tiny Chaos Garden -->
      <article class="border border-foreground/10 rounded-xl overflow-hidden" id="chaos-garden">
        <div class="p-6">
          <div class="flex items-start justify-between mb-3">
            <div>
              <a href="/lab/chaos-garden/" class="text-base font-medium hover:underline">tiny chaos garden</a>
              <p class="text-xs text-muted-foreground mt-0.5">built april 2026</p>
            </div>
            <span class="text-xs px-2 py-0.5 rounded border border-amber-500/30 text-amber-600 dark:text-amber-400 bg-amber-500/5 shrink-0 ml-4">
              toy
            </span>
          </div>
          <p class="text-sm leading-relaxed text-foreground/70 mb-4">
            a personal-site toy: part mood ring, part sticker sheet, part tiny command rebellion.
            click anywhere, drag to boss the particles around, or make the garden stranger.
          </p>

          <div class="border-t border-foreground/5 pt-4 mt-4">
            <div class="grid grid-cols-3 gap-4 text-center">
              <div>
                <div class="text-lg font-medium">p5</div>
                <div class="text-xs text-muted-foreground mt-0.5">canvas garden</div>
              </div>
              <div>
                <div class="text-lg font-medium">tap</div>
                <div class="text-xs text-muted-foreground mt-0.5">spawn chaos</div>
              </div>
              <div>
                <div class="text-lg font-medium">1 file</div>
                <div class="text-xs text-muted-foreground mt-0.5">standalone html</div>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-4 mt-4 pt-4 border-t border-foreground/5">
            <a href="/lab/chaos-garden/" class="text-xs underline hover:no-underline text-muted-foreground">open toy ↗</a>
          </div>
        </div>
      </article>

      <!-- Baby Announcement -->
      <article class="border border-foreground/10 rounded-xl overflow-hidden" id="baby-announcement">
        <div class="p-6">
          <div class="flex items-start justify-between mb-3">
            <div>
              <a href="/lab/baby-announcement/" class="text-base font-medium hover:underline">player 4</a>
              <p class="text-xs text-muted-foreground mt-0.5">march 2026</p>
            </div>
            <span class="text-xs px-2 py-0.5 rounded border border-pink-500/30 text-pink-600 dark:text-pink-400 bg-pink-500/5 shrink-0 ml-4">
              new!
            </span>
          </div>
          <p class="text-sm leading-relaxed text-foreground/70 mb-4">
            retro game-themed baby announcement. player 4 has entered the game —
            due october 2026. press start to play.
          </p>

          <div class="border-t border-foreground/5 pt-4 mt-4">
            <div class="grid grid-cols-3 gap-4 text-center">
              <div>
                <div class="text-lg font-medium">10/8</div>
                <div class="text-xs text-muted-foreground mt-0.5">due date</div>
              </div>
              <div>
                <div class="text-lg font-medium">P4</div>
                <div class="text-xs text-muted-foreground mt-0.5">player</div>
              </div>
              <div>
                <div class="text-lg font-medium">0 deps</div>
                <div class="text-xs text-muted-foreground mt-0.5">pure html/js</div>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-4 mt-4 pt-4 border-t border-foreground/5">
            <a href="/lab/baby-announcement/" class="text-xs underline hover:no-underline text-muted-foreground">press start ↗</a>
          </div>
        </div>
      </article>

      <!-- Iron Log -->
      <article class="border border-foreground/10 rounded-xl overflow-hidden" id="iron-log">
        <div class="p-6">
          <div class="flex items-start justify-between mb-3">
            <div>
              <a href="/lab/iron-log/" class="text-base font-medium hover:underline">iron log</a>
              <p class="text-xs text-muted-foreground mt-0.5">built overnight · feb 2026</p>
            </div>
            <span class="text-xs px-2 py-0.5 rounded border border-emerald-500/30 text-emerald-600 dark:text-emerald-400 bg-emerald-500/5 shrink-0 ml-4">
              active
            </span>
          </div>
          <p class="text-sm leading-relaxed text-foreground/70 mb-4">
            workout tracker built in a single overnight session. logs sets and reps, tracks
            week-over-week progression, and loads today's program based on the day and week.
            4-week push/pull/legs split with scapular rehab built in. no app store, no subscription.
          </p>

          <div class="border-t border-foreground/5 pt-4 mt-4">
            <div class="grid grid-cols-3 gap-4 text-center">
              <div>
                <div class="text-lg font-medium">1 night</div>
                <div class="text-xs text-muted-foreground mt-0.5">build time</div>
              </div>
              <div>
                <div class="text-lg font-medium">4 wk</div>
                <div class="text-xs text-muted-foreground mt-0.5">program</div>
              </div>
              <div>
                <div class="text-lg font-medium">0 deps</div>
                <div class="text-xs text-muted-foreground mt-0.5">pure html/js</div>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-4 mt-4 pt-4 border-t border-foreground/5">
            <a href="/lab/iron-log/" class="text-xs underline hover:no-underline text-muted-foreground">open app ↗</a>
          </div>
        </div>
      </article>

      <!-- Meeting Price Tag -->
      <article class="border border-foreground/10 rounded-xl overflow-hidden" id="meeting-price-tag">
        <div class="p-6">
          <div class="flex items-start justify-between mb-3">
            <div>
              <a href="/lab/meeting-cost/" class="text-base font-medium hover:underline">meeting price tag</a>
              <p class="text-xs text-muted-foreground mt-0.5">built march 2026</p>
            </div>
            <span class="text-xs px-2 py-0.5 rounded border border-emerald-500/30 text-emerald-600 dark:text-emerald-400 bg-emerald-500/5 shrink-0 ml-4">
