---
import Base from '../layouts/Base.astro';
import { labProjects, badgeToneClasses, type LabProject } from '../data/lab';
import { getEpisodes } from '../lib/content';
import { padEpisode, snapshotLabel } from '../lib/format';
import familyosStats from '../../public/familyos-stats.json';
import bishopStats from '../../public/bishop-stats.json';

// Stats render at build time from the repo JSONs (the cron commits them, which
// triggers a deploy anyway) — honest snapshot labels instead of client fetches.
const episodes = await getEpisodes();
const latest = episodes[0];

const overrides: Record<string, Partial<LabProject>> = {
  'signal-room': {
    stats: [
      { value: padEpisode(episodes.length), label: 'episodes' },
      { value: latest?.data.title ?? '—', label: 'latest signal' },
      { value: 'weekly', label: 'cadence' },
    ],
  },
  familyos: {
    stats: [
      { value: String(familyosStats.weeksRunning ?? '—'), label: 'weeks running' },
      { value: String(familyosStats.proposalsSent ?? '—'), label: 'proposals sent' },
      {
        value:
          familyosStats.approvalRate != null
            ? `${Math.round(familyosStats.approvalRate * 100)}%`
            : 'pending',
        label: 'approval rate',
      },
    ],
    statsNote: `snapshot · ${snapshotLabel(familyosStats.updatedAt)}`,
  },
  bishop: {
    stats: [
      { value: String(bishopStats.daysRunning ?? '—'), label: 'days running' },
      { value: String(bishopStats.cronCount ?? '—'), label: 'cron jobs' },
      { value: bishopStats.uptime ?? '24/7', label: 'uptime' },
    ],
    statsNote: `snapshot · ${snapshotLabel(bishopStats.updatedAt)}`,
  },
};

const projects = labProjects.map((p) =>
  overrides[p.id] ? { ...p, ...overrides[p.id] } : p,
);
---

<Base
  title="Lab — Adrian Lumley"
  description="Things I'm building. Some finished, some running, some still figuring out."
>

  <!-- Intro -->
  <section class="mb-12 fade-in">
    <h1 class="text-2xl font-normal mb-3">lab</h1>
    <p class="text-sm leading-relaxed text-foreground/60">
      things i'm building. not a portfolio — an honest record of what's running,
      what's in progress, and what didn't survive contact with reality.
    </p>
  </section>

  <!-- Filter -->
  <section class="mb-8 fade-in">
    <div class="flex flex-wrap gap-2" id="lab-filters" role="group" aria-label="Filter projects by kind">
      <button type="button" class="chip" data-filter="all" aria-pressed="true">all</button>
      <button type="button" class="chip" data-filter="agents" aria-pressed="false">agents</button>
      <button type="button" class="chip" data-filter="tools" aria-pressed="false">tools</button>
      <button type="button" class="chip" data-filter="toys" aria-pressed="false">toys</button>
      <button type="button" class="chip" data-filter="writing" aria-pressed="false">writing</button>
    </div>
  </section>

  <!-- Projects -->
  <section class="space-y-4 fade-in">

    {projects.map((project) => (
      <article class="border border-foreground/10 rounded-xl overflow-hidden" id={project.id} data-category={project.category}>
        <div class="p-6">
          <div class="flex items-start justify-between mb-3">
            <div>
              {project.external ? (
                <a href={project.href} target="_blank" rel="noopener noreferrer" class="text-base font-medium hover:underline">{project.title}</a>
              ) : (
                <a href={project.href} class="text-base font-medium hover:underline">{project.title}</a>
              )}
              <p class="text-xs text-muted-foreground mt-0.5">{project.dateline}</p>
            </div>
            <span class={`text-xs px-2 py-0.5 rounded border shrink-0 ml-4 ${badgeToneClasses[project.badge.tone]}`}>
              {project.badge.label}
            </span>
          </div>
          <p class="text-sm leading-relaxed text-foreground/70 mb-4">{project.description}</p>

          <div class="border-t border-foreground/5 pt-4 mt-4">
            <div class="grid grid-cols-3 gap-4 text-center">
              {project.stats.map((stat) => (
                <div>
                  <div class="text-lg font-medium">{stat.value}</div>
                  <div class="text-xs text-muted-foreground mt-0.5">{stat.label}</div>
                </div>
              ))}
            </div>
            {project.statsNote && (
              <p class="text-[10px] uppercase tracking-wider text-muted-foreground mt-3 text-center">{project.statsNote}</p>
            )}
          </div>

          <div class="flex items-center gap-4 mt-4 pt-4 border-t border-foreground/5">
            {project.links.map((link) =>
              link.external ? (
                <a href={link.href} target="_blank" rel="noopener noreferrer" class="text-xs underline hover:no-underline text-muted-foreground">{link.label}</a>
              ) : (
                <a href={link.href} class="text-xs underline hover:no-underline text-muted-foreground">{link.label}</a>
              ),
            )}
          </div>
        </div>
      </article>
    ))}

    <!-- Placeholder: more to come -->
    <div class="border border-dashed border-foreground/10 rounded-xl p-6 text-center">
      <p class="text-xs text-muted-foreground">more things brewing. check back.</p>
    </div>

  </section>

  <!-- Philosophy -->
  <section class="mt-16 fade-in">
    <p class="text-xs leading-relaxed text-foreground/40">
      i build things i actually use. if they're useful to others, i open source them.
      no launch announcements, no waitlists. just working software that solves real problems.
    </p>
  </section>

</Base>

<script>
  // Filter project cards by kind. Degrades gracefully: with no JS, all cards show.
  const labFilters = document.getElementById('lab-filters');
  if (labFilters) {
    const chips = Array.from(labFilters.querySelectorAll('[data-filter]'));
    const cards = Array.from(document.querySelectorAll('[data-category]'));

    labFilters.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest('[data-filter]') as HTMLElement | null;
      if (!btn) return;
      const filter = btn.dataset.filter;

      chips.forEach((c) => c.setAttribute('aria-pressed', String(c === btn)));
      cards.forEach((card) => {
        const show = filter === 'all' || card.getAttribute('data-category') === filter;
        card.classList.toggle('hidden', !show);
      });
    });
  }
</script>
