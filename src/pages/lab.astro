<script>
  function readCache(key, maxAgeMs) {
    try {
      const cachedRaw = localStorage.getItem(key);
      if (!cachedRaw) return { stats: null, isFresh: false };

      const cached = JSON.parse(cachedRaw);
      const stats = cached.timestamp ? cached.data : cached;

      let isFresh = false;
      if (cached.timestamp && maxAgeMs) {
        const age = Date.now() - cached.timestamp;
        if (age < maxAgeMs) {
          isFresh = true;
        }
      }

      return { stats, isFresh };
    } catch (e) {
      console.warn('Cache read failed', e);
      return { stats: null, isFresh: false };
    }
  }

  function writeCache(key, data) {
    try {
      const cacheData = {
        timestamp: Date.now(),
        data: data
      };
      localStorage.setItem(key, JSON.stringify(cacheData));
    } catch (e) {
      console.warn('Cache write failed', e);
    }
  }

  async function fetchStats(url) {
    const controller = new AbortController();
    const timer = setTimeout(() => controller.abort(), 5000);
    const res = await fetch(url, { signal: controller.signal });
    clearTimeout(timer);
    if (!res.ok) throw new Error('not found');
    return await res.json();
  }

  // Fetch live FamilyOS stats from public JSON (updated by cron after each scan)
  async function loadFamilyOsStats() {
    const loadingEl = document.getElementById('familyos-stats-loading');
    const loadedEl = document.getElementById('familyos-stats-loaded');
    const CACHE_KEY = 'familyos-stats-v1';

    let hasRendered = false;

    function renderStats(stats) {
      if (!stats) return;
      const weeksEl = document.getElementById('stat-weeks');
      const proposalsEl = document.getElementById('stat-proposals');
      const approvalEl = document.getElementById('stat-approval');

      if (weeksEl) weeksEl.textContent = String(stats.weeksRunning ?? '—');
      if (proposalsEl) proposalsEl.textContent = String(stats.proposalsSent ?? '—');
      if (approvalEl) approvalEl.textContent = stats.approvalRate != null
        ? `${Math.round(stats.approvalRate * 100)}%`
        : 'pending';

      if (loadingEl) loadingEl.style.display = 'none';
      if (loadedEl) loadedEl.style.display = 'grid';
      hasRendered = true;
    }

    // 1. Try Cache (5 minutes max age)
    const { stats: cachedStats, isFresh } = readCache(CACHE_KEY, 5 * 60 * 1000);
    if (cachedStats) {
      renderStats(cachedStats);
    }

    if (isFresh) return;

    // 2. Fetch Network
    try {
      const stats = await fetchStats('/familyos-stats.json');
      renderStats(stats);

      // 3. Update Cache
      writeCache(CACHE_KEY, stats);
    } catch (err) {
      if (err.name === 'AbortError' && hasRendered) return;
      // If we haven't shown anything yet, show error state
      if (!hasRendered && loadingEl) {
        loadingEl.textContent = 'stats coming soon';
      }
      // If we already rendered from cache, do nothing (keep showing stale data)
    }
  }

  loadFamilyOsStats();

  // Fetch live Bishop stats from public JSON (updated by cron)
  async function loadBishopStats() {
    const CACHE_KEY = 'bishop-stats-v1';
    const daysEl = document.getElementById('bishop-stat-days');
    const cronsEl = document.getElementById('bishop-stat-crons');

    function renderStats(stats: any) {
      if (!stats) return;
      if (daysEl) daysEl.textContent = String(stats.daysRunning ?? '—');
      if (cronsEl) cronsEl.textContent = String(stats.cronCount ?? '—');
    }

    const { stats: cachedStats } = readCache(CACHE_KEY);
    if (cachedStats) renderStats(cachedStats);

    try {
      const stats = await fetchStats('/bishop-stats.json');
      renderStats(stats);
      writeCache(CACHE_KEY, stats);
    } catch (err) {
      // Keep showing cached or fallback "—"
    }
  }

  loadBishopStats();
</script>

