---
import Base from '../layouts/Base.astro';
import PageIntro from '../components/PageIntro.astro';
import StatTile from '../components/StatTile.astro';
import LiveStatus from '../components/LiveStatus.astro';
import { daysRunning } from '../data/rogue';

// epoch-derived at build time; the LiveStatus script corrects it client side
// so the number never goes stale between deploys.
const rogueDays = daysRunning(new Date());
const toys = [
  { label: 'the crazy wall', href: '/lab/crazy-wall/' },
  { label: 'fable field recorder', href: '/lab/fable-field-recorder/' },
  { label: 'iron log', href: '/lab/iron-log/' },
  { label: 'joytap', href: '/writing/joytap-one-sprint' },
  { label: "my kid's world", href: '/lab/my-kids-world/' },
  { label: 'chaos garden', href: '/lab/chaos-garden/' },
  { label: 'meeting price tag', href: '/lab/meeting-cost/' },
];
---

<Base title="lab" description="things i'm building. not a portfolio, an honest record of what's running and what survived contact with reality.">
  <PageIntro title="lab" standfirst="things i'm building. not a portfolio, an honest record of what's running, what's in progress, and what didn't survive contact with reality." />

  <section class="reveal">
    <article class="card" id="rogue">
      <div class="card-head">
        <h2 class="card-title">rogue</h2>
        <span class="tag">active</span>
      </div>
      <p class="card-copy">the agent i actually use. lives on a mac mini, wired to claude and codex, runs the ops i used to do by hand, and builds things, this site included. signal room is fiction about a system like it.</p>
      <p class="card-copy card-note">i ran a stack of agents and kept the combination that worked.</p>
      <div class="readouts" aria-label="rogue stats">
        <StatTile value={rogueDays} label="days running" />
      </div>
      <p class="mt-5 text-[var(--ink-soft)]"><LiveStatus /></p>
      <a href="/signal-room">read signal room</a>
    </article>
  </section>

  <section class="mt-16 reveal" id="also-built">
    <h2 class="section-title">also built</h2>
    <p class="plain-links">
      {toys.map((toy, index) => (
        <><a href={toy.href}>{toy.label}</a>{index < toys.length - 1 && <span aria-hidden="true">·</span>}</>
      ))}
    </p>
  </section>
</Base>
