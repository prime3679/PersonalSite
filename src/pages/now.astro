---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
---

<Base title="Now" description="What Adrian Lumley is focused on right now — work, building, training, reading, family. Updated March 2026.">
  <Header />
  <main class="mx-auto max-w-2xl px-6 py-12 font-mono">

    <section class="mb-16 fade-in">
      <h1 class="text-2xl font-normal mb-4 leading-relaxed">now.</h1>
      <p class="text-sm text-muted-foreground mb-8">
        this is a <a href="https://nownownow.com/about" class="underline hover:no-underline" target="_blank" rel="noopener noreferrer">now page</a>. updated occasionally. inspired by <a href="https://nownownow.com" class="underline hover:no-underline" target="_blank" rel="noopener noreferrer">nownownow.com</a>.
      </p>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">work:</h2>
      <div class="space-y-3 text-base leading-relaxed">
        <p>at salesforce, working on emerging tech and special projects. zero-to-one products, ai-adjacent, partnership-heavy work. the kind of stuff where you're building the plane while flying it.</p>
      </div>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">building:</h2>
      <div class="space-y-3 text-base leading-relaxed">
        <p><span class="font-semibold text-foreground/80">bishop</span> — my ai chief of staff, running on openclaw. handles calendar, research, comms, and coordinates coding agents. it's the most ambitious personal project i've ever built.</p>
        <p><span class="font-semibold text-foreground/80">la carte</span> — restaurant discovery app. still iterating on what "discovery" actually means.</p>
        <p><span class="font-semibold text-foreground/80">joytap</span> — ios sensory play app for kids.</p>
      </div>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">training:</h2>
      <div class="space-y-3 text-base leading-relaxed">
        <p>muay thai fridays. weight training 2-3x per week. jiu jitsu when the schedule allows. the goal isn't competition — it's showing up consistently and not being soft.</p>
      </div>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">reading:</h2>
      <div class="space-y-3 text-base leading-relaxed">
        <p>brandon sanderson. viet thanh nguyen. rotating between fantasy and literary fiction because i contain multitudes.</p>
      </div>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">family:</h2>
      <div class="space-y-3 text-base leading-relaxed">
        <p>nyc-based. partner and kids. life is full in the best way.</p>
      </div>
    </section>

    <p class="text-xs text-muted-foreground fade-in">last updated: march 2026</p>

  </main>
</Base>
