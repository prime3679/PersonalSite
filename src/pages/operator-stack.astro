---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';

const products = [
  {
    name: 'Morning Brief Generator',
    price: '$3',
    fit: 'buy this if mornings start scattered.',
    copy: 'turn scattered notes into a short daily brief you can actually use.',
    href: 'https://www.shopclawmart.com/listings/morning-brief-generator-d6441723',
    cta: 'buy morning brief',
  },
  {
    name: 'Weekly Review Operator',
    price: '$5',
    fit: 'buy this if the week ends messier than it should.',
    copy: 'close the week cleanly and set up the next one without carrying extra noise.',
    href: 'https://www.shopclawmart.com/listings/weekly-review-operator-6f7c1b22',
    cta: 'buy weekly review',
  },
  {
    name: 'Morning Operator',
    price: '$9',
    fit: 'buy this if the whole system feels loose.',
    copy: 'get the fuller layer: brief, open loops, waiting-fors, and clearer next actions.',
    href: 'https://www.shopclawmart.com/listings/morning-operator-517ef2dd',
    cta: 'buy morning operator',
  },
];

const proof = [
  {
    name: 'Morning Brief Generator',
    input: 'notes, loose tasks, context',
    output: 'a short brief for the day',
  },
  {
    name: 'Weekly Review Operator',
    input: 'the week you just had',
    output: 'a cleaner reset and next-week plan',
  },
  {
    name: 'Morning Operator',
    input: 'your working mess',
    output: 'a clearer operating picture',
  },
];
---

<Base
  title="Operator Stack"
  description="A few simple OpenClaw tools I built for people carrying too many threads at once."
>
  <Header />

  <main class="mx-auto max-w-2xl px-6 py-12 font-mono">
    <section class="mb-16 fade-in">
      <h1 class="text-2xl font-normal mb-6 leading-relaxed">operator stack.</h1>
      <div class="space-y-4 text-base leading-relaxed">
        <p>
          i built these because i kept running into the same problem: too many notes,
          too many loose ends, and no clean picture of what actually mattered.
        </p>
        <p>
          these are small OpenClaw tools for founders, executives, chiefs of staff,
          and product or ops people carrying too much at once.
        </p>
        <p>
          they are cheap on purpose. start with the narrow problem. move up only if you need more.
        </p>
      </div>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">start here:</h2>
      <div class="space-y-3 text-base leading-relaxed">
        <p>— buy the <a href="https://www.shopclawmart.com/listings/morning-brief-generator-d6441723" class="underline hover:no-underline" target="_blank" rel="noopener noreferrer">$3 morning brief</a> if mornings start scattered.</p>
        <p>— buy the <a href="https://www.shopclawmart.com/listings/weekly-review-operator-6f7c1b22" class="underline hover:no-underline" target="_blank" rel="noopener noreferrer">$5 weekly review</a> if your weeks end messy.</p>
        <p>— buy the <a href="https://www.shopclawmart.com/listings/morning-operator-517ef2dd" class="underline hover:no-underline" target="_blank" rel="noopener noreferrer">$9 morning operator</a> if the whole operating picture feels loose.</p>
      </div>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">live now:</h2>
      <div class="space-y-6 text-base leading-relaxed">
        {products.map((product) => (
          <article class="rounded-2xl border border-border p-6">
            <div class="flex items-baseline justify-between gap-4">
              <h3 class="text-lg font-normal">{product.name}</h3>
              <span class="text-sm text-foreground/60">{product.price}</span>
            </div>
            <p class="mt-3">{product.copy}</p>
            <p class="mt-3 text-foreground/70">{product.fit}</p>
            <p class="mt-4">
              → <a href={product.href} class="underline hover:no-underline" target="_blank" rel="noopener noreferrer">{product.cta}</a>
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">what comes out:</h2>
      <div class="space-y-4 text-base leading-relaxed text-foreground/80">
        {proof.map((item) => (
          <p>— <span class="text-foreground">{item.name}</span>: {item.input} → {item.output}</p>
        ))}
      </div>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">before you buy:</h2>
      <div class="space-y-3 text-base leading-relaxed">
        <p>— these buy through Claw Mart.</p>
        <p>— you will create a quick account, download the file, and drop it into OpenClaw.</p>
        <p>— if you are not already using OpenClaw, do not buy this yet.</p>
      </div>
    </section>

    <section class="mb-16 fade-in">
      <h2 class="text-lg font-normal mb-6 uppercase tracking-wider">next:</h2>
      <div class="space-y-3 text-base leading-relaxed">
        <p>Meeting Prep Operator is next. not live yet.</p>
        <p>i am not bundling these yet. if people actually want the stack, i will bundle it later.</p>
      </div>
    </section>
  </main>
</Base>
