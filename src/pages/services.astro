---
import Base from '../layouts/Base.astro';

const services = [
  {
    title: 'ai cost audit',
    availability: 'by request',
    blurb:
      'review your openai or anthropic usage and identify where multi-model routing would reduce spend. most teams overpay because they route everything through their most expensive model. the fix is usually straightforward.',
    items: [
      'spend breakdown by model and task type',
      'routing recommendations with projected savings',
      'implementation guidance, no vendor lock-in',
    ],
  },
  {
    title: 'product advisory',
    availability: 'selective',
    blurb:
      "occasional advisory for early-stage teams building ai-native products. particularly useful if you're navigating 0-to-1, figuring out what to measure, or need someone who's actually shipped at scale to pressure-test your thinking.",
    items: [
      'product strategy and roadmap clarity',
      'team and org design for ai products',
      'investor narrative and positioning',
    ],
  },
];
const metaLabel = 'font-mono text-xs tracking-[.08em] text-[var(--ink-soft)]';
---

<Base
  title="Services"
  description="occasional consulting on ai cost optimization and product strategy, from real experience cutting a production ai stack 70%."
>
  <header class="page-header reveal">
    <h1 class="page-title">services</h1>
    <p class="page-standfirst">
      occasional consulting on ai cost optimization and product strategy.
      based on real experience cutting a production ai stack 70% in cost.
    </p>
  </header>

  <div>
    {services.map((svc, index) => (
      <article class:list={['reveal', index > 0 && 'rule-top mt-16 pt-16']}>
        <p class={metaLabel}>{svc.availability}</p>
        <h2 class="card-title mt-2">{svc.title}</h2>
        <p class="ui-copy mt-3" style="max-width:var(--measure)">{svc.blurb}</p>
        <ul class="list-lines mt-6">
          {svc.items.map((item) => <li>{item}</li>)}
        </ul>
        <p class="plain-links mt-6"><a href="/contact">get in touch</a></p>
      </article>
    ))}
  </div>

  <p class="ui-copy rule-top mt-16 pt-8 reveal" style="max-width:var(--measure)">
    i take on a limited number of projects. if the fit is right, i'll say yes.
  </p>
</Base>
