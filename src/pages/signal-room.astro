import Header from '../components/Header.astro';

const title = "Signal Room";
const description = "A public fiction serial about Rogue, Mission Control, and the odd tenderness of systems trying to help humans without becoming the weather.";
---

<Base title={title} description={description}>
  <Header />
  <main class="mx-auto max-w-2xl px-6 py-12 font-mono">

