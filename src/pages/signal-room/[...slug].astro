---
import Base from '../../layouts/Base.astro';
import PageIntro from '../../components/PageIntro.astro';
import type { CollectionEntry } from 'astro:content';
import { getEpisodes, episodePath, episodeOgPath } from '../../lib/content';
import { episodeTitle, formatLongDate, padEpisode } from '../../lib/format';

export async function getStaticPaths() {
  const episodes = await getEpisodes('asc');

  return episodes.map((episode, i) => ({
    params: { slug: episode.slug },
    props: {
      episode,
      prev: i > 0 ? episodes[i - 1] : null,
      next: i < episodes.length - 1 ? episodes[i + 1] : null,
      first: episodes[0],
    },
  }));
}

interface Props {
  episode: CollectionEntry<'signal-room'>;
  prev: CollectionEntry<'signal-room'> | null;
  next: CollectionEntry<'signal-room'> | null;
  first: CollectionEntry<'signal-room'>;
}

const { episode, prev, next, first } = Astro.props;
const { Content } = await episode.render();

const pageTitle = `${episode.data.title} · signal room`;
---

<Base
  title={pageTitle}
  description={episode.data.teaser}
  ogImage={episodeOgPath(episode.slug)}
  article={{
    headline: episodeTitle(episode.data.episode, episode.data.title),
    description: episode.data.teaser,
    datePublished: episode.data.date.toISOString(),
    url: Astro.url.href,
  }}
>

  <PageIntro title={episode.data.title}>
    <div slot="pretitle">
      <a href="/signal-room/" class="font-sans text-xs uppercase tracking-[.08em] text-[var(--ink-soft)] hover:text-[var(--ink)] transition-colors">← signal room</a>

      <div class="flex flex-wrap gap-2 mt-6 mb-5">
        {episode.data.badges.map((badge) => (
          <span class="font-mono text-[.6875rem] uppercase tracking-[.08em] text-[var(--ink-soft)] border border-[var(--line)] rounded-full px-3 py-1">{badge}</span>
        ))}
        <span class="font-mono text-[.6875rem] uppercase tracking-[.08em] text-[var(--ink-soft)] border border-[var(--line)] rounded-full px-3 py-1">{formatLongDate(episode.data.date)}</span>
      </div>
    </div>
  </PageIntro>

  <article class="prose reveal">
    <Content />
  </article>

  <footer class="mt-16 border-t border-[var(--line)] pt-8 reveal">
    <nav class="flex justify-between gap-6 font-sans text-sm" aria-label="episode navigation">
      {prev ? (
        <a href={episodePath(prev.slug)}>← {padEpisode(prev.data.episode)} · {prev.data.title}</a>
      ) : <span />}
      {next ? (
        <a href={episodePath(next.slug)} class="text-right">{padEpisode(next.data.episode)} · {next.data.title} →</a>
      ) : <span />}
    </nav>
    <p class="ui-copy mt-6">
      signal room · a fiction serial · published on adrianlumley.co
      {episode.data.episode !== 1 && (
        <> · <a href={episodePath(first.slug)}>start from episode 01</a></>
      )}
    </p>
  </footer>

</Base>
