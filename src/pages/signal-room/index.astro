---
import Base from '../../layouts/Base.astro';
import { getEpisodes, episodePath } from '../../lib/content';
import { padEpisode } from '../../lib/format';

const episodes = await getEpisodes('desc');
const latest = episodes[0];
---

<Base title="signal room" description="short fiction about rogue, systems, households, truth, and mercy." ogImage="/og/signal-room.png">
  <header class="page-header reveal">
    <h1 class="page-title">signal room</h1>
    <p class="page-standfirst">short fiction about rogue and the human side of systems that try to help without becoming the weather.</p>
  </header>

  <section class="instrument-panel p-6 md:p-8 reveal" aria-label="signal room episode log">
    <div class="mb-5 flex items-center gap-3 border-b border-[var(--panel-line)] pb-5">
      <span class="font-mono text-xs tracking-[.05em] text-[var(--panel-soft)]">signal.room 07:11</span>
      <span class="h-[.9375rem] w-2 bg-[var(--accent-bright)]" aria-hidden="true"></span>
    </div>
    <ul class="signal-log">
      <li><span class="signal-time">02:22</span><span>rogue marks four items: not morning-safe</span></li>
      <li><span class="signal-time">03:48</span><span>off-site voice requests entry. no door.</span></li>
      <li><span class="signal-time">03:50</span><span>front detected 200mi offshore, unseen by local sensors</span></li>
      <li><span class="signal-time">03:52</span><span>brief compressed to one humane sentence</span></li>
    </ul>
    <p class="signal-highlight">the storm is hours out and nothing is on fire. sleep. i'll have one clean decision waiting for you at six.</p>
    <p class="mt-5 font-mono text-[.625rem] uppercase tracking-[.08em] text-[var(--panel-soft)]">03 · off-site · the one accent in the dark register</p>
  </section>

  {latest && (
    <section class="mt-16 reveal">
      <h2 class="section-title">latest</h2>
      <h2 class="card-title"><a href={episodePath(latest.slug)}>{latest.data.title}</a></h2>
      <p class="ui-copy mt-3">{latest.data.teaser}</p>
    </section>
  )}

  <section class="mt-16 reveal">
    <h2 class="section-title">episodes</h2>
    <div class="content-stack">
      {episodes.map((episode) => (
        <article class="card">
          <p class="font-mono text-xs uppercase tracking-[.08em] text-[var(--ink-soft)]">episode {padEpisode(episode.data.episode)}</p>
          <h2 class="card-title mt-2"><a href={episodePath(episode.slug)}>{episode.data.title}</a></h2>
          <p class="ui-copy mt-3">{episode.data.teaser}</p>
        </article>
      ))}
    </div>
  </section>
</Base>
